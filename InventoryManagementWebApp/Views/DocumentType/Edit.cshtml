@model InventoryManagementWebApp.Models.DocumentType

@{
    ViewData["Title"] = "✏️ დოკუმენტის ტიპის რედაქტირება";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-info text-white p-3 rounded-top-3 d-flex align-items-center justify-content-center">
                    <h2 class="card-title mb-0 fs-3">
                        <i class="bi bi-pencil-square me-2 fs-4"></i>
                        <span class="fw-bold">@ViewData["Title"]</span>
                    </h2>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="DocumentTypeID" />

                        @* Validation summary at the top of the form body *@
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="DocumentName" class="form-label fw-semibold">
                                <i class="bi bi-file-earmark-text-fill me-1"></i> დოკუმენტის სახელი:
                            </label>
                            <input asp-for="DocumentName" class="form-control form-control-lg" placeholder="მაგ: მიღება" autofocus />
                            <span asp-validation-for="DocumentName" class="text-danger small mt-1"></span>
                        </div>

                        <div class="d-flex justify-content-center flex-wrap gap-3 pt-3 border-top mt-4">
                            <button type="submit" class="btn btn-success btn-lg px-4" title="შენახვა">
                                <i class="bi bi-save-fill me-2"></i> 💾 შენახვა
                            </button>
                            <a asp-action="Index" class="btn btn-secondary btn-lg px-4" title="დაბრუნება">
                                <i class="bi bi-arrow-left-circle-fill me-2"></i> 🔙 დაბრუნება
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}