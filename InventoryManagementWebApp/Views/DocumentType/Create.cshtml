@model InventoryManagementWebApp.Models.DocumentType

@{
    ViewData["Title"] = "➕ ახალი დოკუმენტის ტიპის დამატება";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9 col-sm-12">
            @* Adjusted column width for slightly wider form area *@
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-info text-white p-3 rounded-top-3 d-flex align-items-center justify-content-center">
                    @* Changed header color to info (light blue) *@
                    <h2 class="card-title mb-0 fs-3">
                        <i class="bi bi-plus-square-fill me-2 fs-4"></i>
                        <span class="fw-bold">@ViewData["Title"]</span>
                    </h2>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                        <div class="row g-3">
                            <div class="col-12 mb-3">
                                <label asp-for="DocumentName" class="form-label fw-semibold">
                                    <i class="bi bi-file-earmark-text-fill me-1"></i> დოკუმენტის სახელი:
                                </label>
                                <input asp-for="DocumentName" class="form-control form-control-lg" placeholder="მაგ: მიღება" autofocus aria-describedby="nameHelp" />
                                <div id="nameHelp" class="form-text text-muted">დოკუმენტის ტიპის სრული დასახელება.</div>
                                <span asp-validation-for="DocumentName" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-12 text-center pt-3 border-top mt-4">
                                <div class="d-flex justify-content-center flex-wrap gap-3">
                                    <button type="submit" class="btn btn-success btn-lg px-4" title="შენახვა">
                                        <i class="bi bi-save-fill me-2"></i> 💾 დამატება
                                    </button>
                                    <a asp-action="Index" class="btn btn-secondary btn-lg px-4" title="დაბრუნება">
                                        <i class="bi bi-arrow-left-circle-fill me-2"></i> 🔙 დაბრუნება
                                    </a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}