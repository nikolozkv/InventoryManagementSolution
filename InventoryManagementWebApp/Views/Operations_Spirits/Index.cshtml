@model InventoryManagementWebApp.Models.OperationsSpiritPageViewModel

@{
    ViewData["Title"] = "სპირტის ოპერაციები";

    // ლოკალური ფუნქცია ასაკის გამოსათვლელად
    string GetAgeString(DateTime? date)
    {
        if (!date.HasValue) return "უცნობი";
        var now = DateTime.Now;
        var years = now.Year - date.Value.Year;
        var months = now.Month - date.Value.Month;
        if (now.Day < date.Value.Day) months--;
        if (months < 0) { years--; months += 12; }

        if (years == 0 && months == 0) return "ახალი გამოხდილი";
        string res = "";
        if (years > 0) res += $"{years} წ. ";
        if (months > 0) res += $"{months} თვ.";
        return res.Trim();
    }
}

<div class="container-fluid py-4">
    <h2 class="mb-4 text-center fw-bold">სპირტის კასრზე ჩატარებული ოპერაციები</h2>
    <hr class="mb-5" />

    <div class="row gx-4">
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0 fs-5"><i class="bi bi-info-circle-fill me-2"></i> კასრის დეტალები</h5>
                </div>
                <div class="card-body">
                    <h4 class="card-title text-primary fw-bold">@Model.CompanyTypeName - @Model.CompanyName</h4>
                    <h5 class="card-text mb-0 mt-2 fs-5"><strong>ლოტი:</strong> @Model.CompanyLot</h5>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h6 class="mb-0 fs-6 fw-bold">მიმდინარე სტატუსი</h6>
                </div>
                <div class="card-body">
                    <h5 class="card-subtitle mb-3 text-muted fw-bold">კასრი: @Model.BeverageName</h5>
                    
                    <p class="card-text mb-2 fs-5">
                        <i class="bi bi-droplet-fill me-2 text-primary"></i> <strong>ნაშთი:</strong> @Model.CurrentVolume.ToString("0.##") ლ
                    </p>

                    <p class="card-text mb-2 fs-5">
                        <i class="bi bi-hourglass-split me-2 text-warning"></i> <strong>ასაკი:</strong> 
                        <span class="badge bg-warning text-dark fs-6">@GetAgeString(Model.WeightedAvgDate)</span>
                    </p>

                    <p class="card-text mb-1 fs-5">
                        <i class="bi bi-percent me-2 text-danger"></i> <strong>ალკოჰოლი:</strong> 
                        <span class="fw-bold">@(Model.CurrentAlcPercent.HasValue ? Model.CurrentAlcPercent.Value.ToString("0.##") + "%" : "უცნობი")</span>
                    </p>
                </div>
            </div>

            <div class="card shadow-sm h-md-100-flex">
                <div class="card-header bg-light">
                    <h6 class="mb-0 fs-6 fw-bold">მახასიათებლები</h6>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0 fs-5">
                        <li class="mb-2"><i class="bi bi-tag-fill me-2 text-info"></i> <strong>სასმელი:</strong> @Model.ProductType</li>
                        <li class="mb-2"><i class="bi bi-list-nested me-2 text-info"></i> <strong>კატეგორია:</strong> @Model.Category</li>
                        <li><i class="bi bi-palette-fill me-2 text-info"></i> <strong>ფერი:</strong> @Model.Color</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-8 col-md-6 mb-4">
            <div class="card h-100 shadow-sm d-flex flex-column">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0 fs-5"><i class="bi bi-plus-circle-fill me-2"></i> ახალი ოპერაცია</h5>
                </div>
                <div class="card-body overflow-auto">
                    <form asp-action="Create" method="post" id="operationForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="BarrelID" value="@Model.BarrelID" />
                        <input type="hidden" name="BeverageID" value="@Model.BeverageID" />
                        <input type="hidden" name="OperType" id="OperType" />
                        <input type="hidden" id="OperationID" name="OperationID" value="0" />

                        <script>
                            var operationDefinitionsData = @Html.Raw(Json.Serialize(ViewBag.OperationDefinitionsFull));
                        </script>

                        <div class="row g-2">
                            <div class="col-lg-6 col-md-12">
                                <div class="d-flex align-items-center mb-2">
                                    <label for="OperationDefID" class="form-label compact-label fs-6"><i class="bi bi-hand-index-thumb text-primary me-2"></i> ოპერაცია</label>
                                    <select name="OperationDefID" id="OperationDefID" class="form-select form-select-sm flex-grow-1" required>
                                        <option value="">აირჩიეთ</option>
                                        @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.OperationDefinitions)
                                        {
                                            <option value="@item.Value">@item.Text</option>
                                        }
                                    </select>
                                </div>

                                <div class="d-flex align-items-center mb-2">
                                    <label for="TransactionDate" class="form-label compact-label fs-6"><i class="bi bi-calendar-date-fill text-success me-2"></i> თარიღი</label>
                                    <input type="date" name="TransactionDate" id="TransactionDate" class="form-control form-control-sm flex-grow-1" max="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                                </div>

                                <div class="d-flex align-items-center mb-2">
                                    <label for="Quantity" class="form-label compact-label fs-6"><i class="bi bi-clipboard-data-fill text-danger me-2"></i> სულ ლიტრი</label>
                                    <input type="number" step="0.01" name="Quantity" id="Quantity" class="form-control form-control-sm flex-grow-1" required />
                                </div>

                                <div class="d-flex align-items-center mb-2">
                                    <label for="DocumentTypeID" class="form-label compact-label fs-6"><i class="bi bi-file-earmark-text-fill text-info me-2"></i> საბუთის ტიპი</label>
                                    <select name="DocumentTypeID" id="DocumentTypeID" class="form-select form-select-sm flex-grow-1" required>
                                        <option value="">აირჩიეთ</option>
                                        @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.DocumentTypes)
                                        {
                                            <option value="@item.Value">@item.Text</option>
                                        }
                                    </select>
                                </div>

                                <div class="d-flex align-items-center mb-2">
                                    <label for="DocumentNumber" class="form-label compact-label fs-6"><i class="bi bi-hash text-secondary me-2"></i> საბუთის №</label>
                                    <input type="text" name="DocumentNumber" id="DocumentNumber" class="form-control form-control-sm flex-grow-1" required />
                                </div>
                            </div>

                            <div class="col-lg-6 col-md-12">
                                <div id="companyBarrelFields" style="display:none;">
                                    <div class="d-flex align-items-center mb-2" id="companySearchDiv">
                                        <label for="CompanySearch" class="form-label compact-label fs-6"><i class="bi bi-search text-secondary me-2"></i> კომპანიის ძიება</label>
                                        <input type="text" id="CompanySearch" class="form-control form-control-sm flex-grow-1" placeholder="ჩაწერე კომპანია" />
                                    </div>

                                    <div class="d-flex align-items-center mb-2" id="companySelectDiv">
                                        <label for="OppositeCompanyID" class="form-label compact-label fs-6"><i class="bi bi-building text-primary me-2"></i> კომპანია</label>
                                        <select name="OppositeCompanyID" id="OppositeCompanyID" class="form-select form-select-sm flex-grow-1"></select>
                                    </div>

                                    <div class="d-flex align-items-center mb-2">
                                        <label for="BarrelSearch" class="form-label compact-label fs-6"><i class="bi bi-search text-secondary me-2"></i> კასრის ძიება</label>
                                        <input type="text" id="BarrelSearch" class="form-control form-control-sm flex-grow-1" placeholder="ჩაწერე კასრი" />
                                    </div>

                                    <div class="d-flex align-items-center mb-2">
                                        <label for="OppositeBarrelID" class="form-label compact-label fs-6"><i class="bi bi-barrel-fill text-warning me-2"></i> წყარო კასრი</label>
                                        <select id="OppositeBarrelID" name="OppositeBarrelID" class="form-select form-select-sm flex-grow-1"></select>
                                    </div>
                                </div>

                                <div id="distillationFields" style="display:none;" class="p-2 border border-warning rounded bg-warning bg-opacity-10 mb-2">
                                    <div class="d-flex align-items-center mb-2">
                                        <label for="WineAlcPercent" class="form-label compact-label fs-6"><i class="bi bi-moisture text-primary me-1"></i> ღვინის ალკოჰოლი %</label>
                                        <input type="number" step="0.01" name="WineAlcPercent" id="WineAlcPercent" class="form-control form-control-sm flex-grow-1" placeholder="მაგ. 11.5" />
                                    </div>
                                    <div class="d-flex align-items-center mb-1">
                                        <label for="LossPercent" class="form-label compact-label fs-6"><i class="bi bi-graph-down-arrow text-danger me-1"></i> დანაკარგი %</label>
                                        <input type="number" step="0.01" name="LossPercent" id="LossPercent" class="form-control form-control-sm flex-grow-1" placeholder="მაგ. 2.5" />
                                    </div>
                                </div>

                                <div id="readOnlyInfoFields" class="mt-3">
                                    <div class="d-flex align-items-center mb-2">
                                        <label for="VolumeBefore" class="form-label compact-label fs-6"><i class="bi bi-box-fill text-secondary me-2"></i> ნაშთი თარიღისთვის</label>
                                        <input type="text" id="VolumeBefore" class="form-control form-control-sm flex-grow-1 fw-bold" readonly />
                                    </div>

                                    <div class="d-flex align-items-center mb-2" id="limitDiv" style="display:none;">
                                        <label for="MaxAllowed" class="form-label compact-label text-danger fs-6"><i class="bi bi-speedometer2 me-2"></i> დაშვებული ლიმიტი</label>
                                        <input type="text" id="MaxAllowed" class="form-control form-control-sm flex-grow-1 border-danger text-danger fw-bold" readonly />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                
                <!-- V. Action Buttons -->
                <div class="card-footer bg-light d-flex justify-content-between p-3 sticky-bottom-custom">
                    <div class="d-flex gap-4">

                        @* --- გამყოფი ხაზი (ვიზუალური დაშორებისთვის) --- *@
                        <div class="vr mx-5"></div>

                        <button type="submit" class="btn btn-success btn-lg" id="AddButton" form="operationForm">
                        <i class="bi bi-plus-circle-fill me-2"></i> დამატება
                        </button>

                        @* --- გამყოფი ხაზი (ვიზუალური დაშორებისთვის) --- *@
                        <div class="vr mx-2"></div>

                        <button type="button" class="btn btn-info btn-lg" id="LoadFromClipboardBtn">
                            <i class="bi bi-clipboard-check me-2"></i> ჩატვირთვა
                        </button>
                    </div>

                    <a asp-controller="CompanyBarrelSpiritDetails" asp-action="Index" asp-route-companyId="@Model.CompanyID" class="btn btn-secondary btn-lg">
                        <i class="bi bi-arrow-left-circle-fill me-2"></i> უკან
                    </a>
                </div>
            </div>
        </div>
    </div>

    <h3 class="mb-3 mt-5 fw-bold"><i class="bi bi-clock-history text-primary me-2"></i> ოპერაციების ისტორია</h3>
    @if (Model.Operations?.Any() == true)
    {
        <div class="table-responsive bg-white rounded shadow-sm border">
            <table class="table table-striped mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="fs-6 py-2">თარიღი</th>
                        <th class="fs-6 py-2">საბუთი</th>
                        <th class="fs-6 py-2">№</th>
                        <th class="fs-6 py-2">სასმელი</th>
                        <th class="fs-6 py-2">ტიპი</th>
                        <th class="fs-6 py-2">კატეგ.</th>
                        <th class="fs-6 py-2">ლიტრი</th>
                        <th class="fs-6 py-2">ოპერაცია</th>
                        <th class="fs-6 py-2">ნაშთი</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var op in Model.Operations)
                    {
                        var rowClass = op.Quantity.StartsWith("-") ? "table-danger" : "table-success";
                        <tr class="@rowClass">
                            <td>@op.TransactionDate.ToString("yyyy-MM-dd")</td>
                            <td>@op.DocumentTypeName</td>
                            <td>@op.DocumentNumber</td>
                            <td>
                                @op.BeverageName
                                <div style="text-align: right; font-size: small; font-weight: bold; color: black;">
                                    @op.ExecutedByUserFirstName @op.ExecutedByUserLastName
                                </div>
                            </td>
                            <td>@op.ProductType</td>
                            <td>@op.Category</td>
                            <td class="fw-bold fs-6">@op.Quantity</td>
                            <td>
                                @op.OperName
                                @if (!string.IsNullOrEmpty(op.SourceCompanyName) && op.SourceBarrelID != null)
                                {
                                    <div style="text-align: left; font-size: small; font-weight: bold; color: black;">
                                        <a href="@Url.Action("Index", "Operations", new { barrelId = op.SourceBarrelID })" title="გადასვლა კასრზე">
                                            <i class="bi bi-box-arrow-up-right text-primary me-1"></i> @op.SourceCompanyName: #@op.SourceBarrelID
                                        </a>
                                    </div>
                                }
                            </td>
                            <td class="fw-bold">@op.VolumeLeft</td>
                            <td class="text-end">
                                <form asp-action="Delete" method="post" class="delete-form d-inline">
                                    <input type="hidden" name="operationId" value="@op.OperationID" />
                                    <button type="submit" class="btn btn-danger btn-sm" title="წაშლა"><i class="bi bi-trash-fill"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <style>
        body {
            background-color: #e9f2fa; /* ცივი ცისფერი ფონი */
        }
        .compact-label { width: 140px; flex-shrink: 0; margin-right: 0.5rem; text-align: right; margin-bottom: 0 !important; font-size: 0.875rem; }
        .table-responsive { max-height: 500px; overflow-y: auto; overflow-x: auto; width: 100%; }
        .table-responsive .table td, .table-responsive .table th { white-space: nowrap; }
        .table thead th { position: sticky; top: 0; background-color: var(--bs-table-bg, #f8f9fa); z-index: 2; box-shadow: 0 2px 2px -1px rgba(0,0,0,0.1); }
        .table th:last-child, .table td:last-child { position: sticky; right: 0; background-color: var(--bs-table-bg, #f8f9fa); z-index: 1; box-shadow: -2px 0 5px rgba(0,0,0,0.05); }
        .table thead th:last-child { z-index: 3; }
        input[readonly], select[readonly] { background-color: #e9ecef; opacity: 1; cursor: default; }

        /* პლანშეტზე ან პატარა ეკრანზე დიზაინი არ "გაიქცეს" */
        @@media (min-width: 768px) {
            .col-lg-4.col-md-6 {
                display: flex;
                flex-direction: column;
            }
            .col-lg-4.col-md-6 .card:last-child {
                flex-grow: 1;
            }
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Caching DOM elements
            const opDefSelect = document.getElementById('OperationDefID');
            const operTypeInput = document.getElementById('OperType');
            const compBarrelFields = document.getElementById('companyBarrelFields');
            const distFields = document.getElementById('distillationFields');
            const limitDiv = document.getElementById('limitDiv');
            
            const oppCompSelect = document.getElementById('OppositeCompanyID');
            const oppBarrelSelect = document.getElementById('OppositeBarrelID');
            const compSearchDiv = document.getElementById('companySearchDiv');
            const compSelectDiv = document.getElementById('companySelectDiv');
            
            const transDateInput = document.getElementById('TransactionDate');
            const volBeforeInput = document.getElementById('VolumeBefore');
            const maxAllowedInput = document.getElementById('MaxAllowed');
            const addButton = document.getElementById('AddButton');

            const barrelId = @Model.BarrelID;

            // 1. ოპერაციის ტიპის არჩევა და ველების გამოჩენა/დამალვა
            opDefSelect.addEventListener('change', async function () {
                const selectedId = this.value;
                if (!selectedId) {
                    resetFields();
                    return;
                }

                const selected = operationDefinitionsData.find(o => o.operationDefID == selectedId);
                if (selected) {
                    operTypeInput.value = selected.operType;
                    await handleOperTypeLogic(selected.operType);
                }
            });

            async function handleOperTypeLogic(operType) {
                // Reset states
                compBarrelFields.style.display = 'none';
                distFields.style.display = 'none';
                limitDiv.style.display = 'none';
                
                oppCompSelect.innerHTML = '<option value="">აირჩიეთ კომპანია</option>';
                oppBarrelSelect.innerHTML = '<option value="">აირჩიეთ კასრი</option>';

                if (operType == 2 || operType == 4 || operType == 5) {
                    compBarrelFields.style.display = 'block';
                    compSearchDiv.style.display = 'none'; 
                    compSelectDiv.style.display = 'none';
                    
                    if (operType == 5) {
                        distFields.style.display = 'block'; 
                    }
                    
                    await loadBarrels(operType, null);
                } 
                else if (operType == 3) {
                    compBarrelFields.style.display = 'block';
                    compSearchDiv.style.display = 'flex';
                    compSelectDiv.style.display = 'flex';
                    await loadCompanies();
                }
                
                updateVolumeByDate();
            }

            async function loadCompanies() {
                try {
                    const response = await fetch(`/api/operations-spirit/filtered-companies?barrelId=${barrelId}`);
                    const companies = await response.json();
                    companies.forEach(c => oppCompSelect.innerHTML += `<option value="${c.value}">${c.text}</option>`);
                } catch (e) { console.error("Error loading companies", e); }
            }

            async function loadBarrels(operType, companyId) {
                try {
                    let url = `/api/operations-spirit/filtered-barrels?barrelId=${barrelId}&operType=${operType}`;
                    if (companyId) url += `&companyId=${companyId}`;
                    
                    const response = await fetch(url);
                    const barrels = await response.json();
                    oppBarrelSelect.innerHTML = '<option value="">აირჩიეთ კასრი</option>';
                    barrels.forEach(b => oppBarrelSelect.innerHTML += `<option value="${b.value}">${b.text}</option>`);
                } catch (e) { console.error("Error loading barrels", e); }
            }

            oppCompSelect.addEventListener('change', function() {
                if (this.value) loadBarrels(3, this.value);
            });

            // 2. თარიღით ნაშთების და ლიმიტების გადათვლა
            oppBarrelSelect.addEventListener('change', updateVolumeByDate);
            transDateInput.addEventListener('change', updateVolumeByDate);

            async function updateVolumeByDate() {
                const operType = operTypeInput.value;
                const oppBarrelId = oppBarrelSelect.value;
                const date = transDateInput.value;

                volBeforeInput.value = "0.00 ლ";
                maxAllowedInput.value = "0.00 ლ";
                addButton.disabled = true;

                if (!operType || !date) return;
                if ((operType == 2 || operType == 3 || operType == 4 || operType == 5) && !oppBarrelId) return;

                try {
                    const url = `/api/operations-spirit/get-data-by-transdate?operType=${operType}&barrelId=${barrelId}&oppositeBarrelId=${oppBarrelId || 0}&transactionDate=${date}`;
                    const response = await fetch(url);
                    const data = await response.json();

                    volBeforeInput.value = (data.volume || 0).toFixed(2) + " ლ";

                    // ლიმიტის ლოგიკა:
                            if (data.maxAllowed === -1) {
                                maxAllowedInput.value = "ლიმიტის გარეშე";
                            } else {
                                maxAllowedInput.value = (data.maxAllowed || 0).toFixed(2) + " ლ";
                            }

                            addButton.disabled = false;
                        } catch (error) {
                            // შეცდომის შემთხვევაშიც არ დავტოვოთ ცარიელი
                            volBeforeInput.value = "0.00 ლ";
                            maxAllowedInput.value = "0.00 ლ";
                            addButton.disabled = true;
                        }
                    }

            function resetFields() {
                operTypeInput.value = '';
                compBarrelFields.style.display = 'none';
                distFields.style.display = 'none';
                limitDiv.style.display = 'none';
                volBeforeInput.value = '';
                addButton.disabled = true;
            }

            // ----------------------------------------------------
            // 3. F1 Clipboard ლოგიკა (გასწორებული ცვლადებით)
            // ----------------------------------------------------
            const loadFromClipboardBtn = document.getElementById('LoadFromClipboardBtn');
            const documentTypeSelect = document.getElementById('DocumentTypeID');
            const documentNumberInput = document.getElementById('DocumentNumber');
            
            if (loadFromClipboardBtn) {
                loadFromClipboardBtn.addEventListener('click', function() {
                    try {
                        console.log('Loading clipboard data...');
                        const clipboardData = window.getClipboardData ? window.getClipboardData() : {};
                        let fieldsLoaded = 0;
                        
                        // Load საბუთი
                        if (clipboardData.sabuti && documentTypeSelect) {
                            if (clipboardData.sabuti) {
                                documentTypeSelect.value = clipboardData.sabuti;
                                if (documentTypeSelect.value) fieldsLoaded++;
                            }
                            
                            if (!documentTypeSelect.value && clipboardData.sabutiText) {
                                const sabutiText = clipboardData.sabutiText.toLowerCase().trim();
                                const options = Array.from(documentTypeSelect.options);
                                const matchedOption = options.find(option => 
                                    option.text.toLowerCase().includes(sabutiText) || 
                                    sabutiText.includes(option.text.toLowerCase())
                                );
                                if (matchedOption) {
                                    documentTypeSelect.value = matchedOption.value;
                                    fieldsLoaded++;
                                }
                            }
                        }
                        
                        // Load N
                        if (clipboardData.number && documentNumberInput) {
                            documentNumberInput.value = clipboardData.number;
                            fieldsLoaded++;
                        }
                        
                        // Load თარიღი
                        if (clipboardData.date && transDateInput) {
                            transDateInput.value = clipboardData.date;
                            fieldsLoaded++;
                            transDateInput.dispatchEvent(new Event('change'));
                        }
                        
                        // UI განახლება
                        if (fieldsLoaded > 0) {
                            loadFromClipboardBtn.innerHTML = '<i class="bi bi-check-circle me-2"></i> ჩაიტვირთა';
                            loadFromClipboardBtn.classList.replace('btn-info', 'btn-success');
                            setTimeout(() => {
                                loadFromClipboardBtn.innerHTML = '<i class="bi bi-clipboard-check me-2"></i> ჩატვირთვა';
                                loadFromClipboardBtn.classList.replace('btn-success', 'btn-info');
                            }, 1000);
                        } else {
                            loadFromClipboardBtn.innerHTML = '<i class="bi bi-exclamation-triangle me-2"></i> ცარიელია';
                            loadFromClipboardBtn.classList.replace('btn-info', 'btn-warning');
                            setTimeout(() => {
                                loadFromClipboardBtn.innerHTML = '<i class="bi bi-clipboard-check me-2"></i> ჩატვირთვა';
                                loadFromClipboardBtn.classList.replace('btn-warning', 'btn-info');
                            }, 1000);
                        }
                    } catch (error) {
                        console.error('Error loading clipboard data:', error);
                        loadFromClipboardBtn.innerHTML = '<i class="bi bi-x-circle me-2"></i> შეცდომა';
                        loadFromClipboardBtn.classList.replace('btn-info', 'btn-danger');
                        setTimeout(() => {
                            loadFromClipboardBtn.innerHTML = '<i class="bi bi-clipboard-check me-2"></i> ჩატვირთვა';
                            loadFromClipboardBtn.classList.replace('btn-danger', 'btn-info');
                        }, 2000);
                    }
                });
            }
            
            // ----------------------------------------------------
            // 4. შეცდომის დროს ფორმის აღდგენა
            // ----------------------------------------------------
            const formDataJson = @Html.Raw(Json.Serialize(TempData["FormData"]?.ToString() ?? ""));
            if (formDataJson && formDataJson !== "") {
                try {
                    const formData = JSON.parse(formDataJson);
                    if (formData.OperationDefID) {
                        opDefSelect.value = formData.OperationDefID;
                        opDefSelect.dispatchEvent(new Event('change'));
                        
                        setTimeout(() => {
                            if (formData.TransactionDate) {
                                transDateInput.value = formData.TransactionDate.split('T')[0];
                                transDateInput.dispatchEvent(new Event('change'));
                            }
                            if (formData.Quantity && document.getElementById('Quantity')) {
                                document.getElementById('Quantity').value = formData.Quantity;
                            }
                            if (formData.DocumentTypeID && documentTypeSelect) {
                                documentTypeSelect.value = formData.DocumentTypeID;
                            }
                            if (formData.DocumentNumber && documentNumberInput) {
                                documentNumberInput.value = formData.DocumentNumber;
                            }
                            
                            if (formData.OppositeCompanyID && oppCompSelect) {
                                oppCompSelect.value = formData.OppositeCompanyID;
                                oppCompSelect.dispatchEvent(new Event('change'));
                                if (formData.OppositeBarrelID) {
                                    setTimeout(() => {
                                        if (oppBarrelSelect) {
                                            oppBarrelSelect.value = formData.OppositeBarrelID;
                                            oppBarrelSelect.dispatchEvent(new Event('change'));
                                        }
                                    }, 1000);
                                }
                            } else if (formData.OppositeBarrelID && oppBarrelSelect) {
                                setTimeout(() => {
                                    oppBarrelSelect.value = formData.OppositeBarrelID;
                                    oppBarrelSelect.dispatchEvent(new Event('change'));
                                }, 500);
                            }
                        }, 500);
                    }
                } catch (error) { console.error('Error restoring form data:', error); }
            }

        });
    </script>
}