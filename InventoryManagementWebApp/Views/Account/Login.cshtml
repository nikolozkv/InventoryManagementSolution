@model LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<style>
    .login-container {
        max-width: 500px;
        margin: 50px auto;
        padding: 30px;
        background-color: #ffffff;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        text-align: center;
    }

    .login-title {
        color: #2c3e50;
        font-size: 2.5rem;
        margin-bottom: 20px;
        font-weight: 700;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.05);
    }

    .form-label {
        font-weight: 600;
        color: #34495e;
    }

    .text-danger {
        color: #e74c3c !important;
    }

    .btn-primary {
        background-color: #3498db;
        border-color: #3498db;
        text-align: center;
        width: 150px;
        margin: 0 auto;
        display: block;
    }

    .btn-primary:hover {
        background-color: #2980b9;
        border-color: #2980b9;
    }
</style>

<div class="login-container">
    <h1 class="login-title">🔐 Login</h1>

    <form asp-action="Login" method="post">
        <div asp-validation-summary="All" class="text-danger" role="alert"></div>

        <div class="mb-4">
            <label asp-for="UsernameOrEmail" class="form-label">Username or Email</label>
            <input asp-for="UsernameOrEmail" class="form-control" placeholder="Enter your username or email" />
            <span asp-validation-for="UsernameOrEmail" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Password" class="form-label">Password</label>
            <input asp-for="Password" class="form-control" type="password" placeholder="Enter your password" autocomplete="current-password" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <input type="hidden" asp-for="ReturnUrl" />

        <div class="d-grid gap-2">
            <button type="submit" class="btn btn-primary btn">Login</button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
