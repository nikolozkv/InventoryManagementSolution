@model InventoryManagementWebApp.Models.Company
@{
    ViewData["Title"] = "კომპანიის რეაქტივაცია";
}

<div class="container py-2">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9 col-sm-12">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-success text-white p-3 rounded-top-3 d-flex align-items-center justify-content-center">
                    <h2 class="card-title mb-0 fs-3">
                        <span class="fw-bold">♻️ კომპანიის რეაქტივაცია</span>
                    </h2>
                </div>
                <div class="card-body p-4">

                    <div class="alert alert-info d-flex align-items-center mb-4" role="alert">
                        <i class="bi bi-info-circle-fill flex-shrink-0 me-2 fs-4"></i>
                        <div>
                            ეს კომპანია არქივირებულია. გსურთ მისი <strong>რეაქტივაცია (აღდგენა)</strong>?
                        </div>
                    </div>

                    <dl class="row mb-4">
                        <dt class="col-sm-4 text-muted">კომპანიის სახელი:</dt>
                        <dd class="col-sm-8 fw-bold">@Model.Name</dd>

                        <dt class="col-sm-4 text-muted">საიდენტიფიკაციო კოდი:</dt>
                        <dd class="col-sm-8">@Model.IdentifierCode</dd>

                        <dt class="col-sm-4 text-muted">ლოტის კოდი:</dt>
                        <dd class="col-sm-8">@Model.CompanyLot</dd>
                    </dl>

                    <form asp-action="CompanyReactivate" method="post" class="col-12 text-center pt-3 border-top">
                        <input type="hidden" asp-for="CompanyID" />
                        <div class="d-flex justify-content-center flex-wrap gap-3">
                            <button type="submit" class="btn btn-success btn-lg px-4">
                                <i class="bi bi-arrow-counterclockwise me-2"></i> რეაქტივაცია
                            </button>
                            <a asp-action="Index" class="btn btn-secondary btn-lg px-4">
                                <i class="bi bi-arrow-left-circle-fill me-2"></i> უკან
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>