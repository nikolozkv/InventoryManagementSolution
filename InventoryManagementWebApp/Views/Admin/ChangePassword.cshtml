@model InventoryManagementWebApp.Models.ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
}

<style>
    .change-password-container {
        max-width: 600px;
        margin: 50px auto;
        padding: 30px;
        background-color: #ffffff;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .change-password-title {
        color: #2c3e50;
        font-size: 2.5rem;
        margin-bottom: 20px;
        font-weight: 700;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.05);
        text-align: center;
    }

    .form-label {
        font-weight: 600;
        color: #34495e;
    }

    .form-control {
        margin-bottom: 15px;
    }

    .btn-primary {
        background-color: #3498db;
        border-color: #3498db;
    }

    .btn-primary:hover {
        background-color: #2980b9;
        border-color: #2980b9;
    }

    .btn-secondary {
        background-color: #95a5a6;
        border-color: #95a5a6;
    }

    .btn-secondary:hover {
        background-color: #7f8c8d;
        border-color: #7f8c8d;
    }

    .password-requirements {
        background-color: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 5px;
        padding: 15px;
        margin-bottom: 20px;
    }

    .password-requirements h6 {
        color: #495057;
        margin-bottom: 10px;
    }

    .password-requirements ul {
        margin-bottom: 0;
        padding-left: 20px;
    }

    .password-requirements li {
        color: #6c757d;
        font-size: 0.9rem;
    }
</style>

<div class="change-password-container">
    <h1 class="change-password-title">Change Password</h1>
    <p class="text-center text-muted mb-4">Changing password for: <strong>@Model.Username</strong></p>

    @* <div class="password-requirements">
        <h6>Password Requirements:</h6>
        <ul>
            <li>Must be at least 6 characters long</li>
            <li>Should contain a mix of letters, numbers, and special characters</li>
            <li>Avoid using common words or personal information</li>
        </ul>
    </div> *@

    <form asp-action="ChangePassword" method="post">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="Username" />

        <div class="mb-3">
            <label asp-for="NewPassword" class="form-label">New Password</label>
            <input asp-for="NewPassword" class="form-control" type="password" autocomplete="new-password" />
            <span asp-validation-for="NewPassword" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ConfirmNewPassword" class="form-label">Confirm New Password</label>
            <input asp-for="ConfirmNewPassword" class="form-control" type="password" autocomplete="new-password" />
            <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
        </div>

        <div class="d-grid gap-2 d-md-flex justify-content-md-start">
            <button type="submit" class="btn btn-primary">Change Password</button>
            <a asp-action="EditUser" asp-route-id="@Model.UserId" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}