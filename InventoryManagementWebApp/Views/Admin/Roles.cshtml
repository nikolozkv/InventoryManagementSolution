@model IEnumerable<InventoryManagementWebApp.Models.RoleModel>

@{
    ViewData["Title"] = "Manage Roles";
}

<style>
    .roles-container {
        max-width: 1000px;
        margin: 50px auto;
        padding: 30px;
        background-color: #ffffff;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .roles-title {
        color: #2c3e50;
        font-size: 2.5rem;
        margin-bottom: 20px;
        font-weight: 700;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.05);
        text-align: center;
    }

    .table {
        margin-top: 20px;
    }

    .btn {
        font-size: 0.9rem;
        padding: 0.4em 0.8em;
    }

    .alert {
        margin-bottom: 20px;
    }
</style>

<div class="roles-container">
    <h1 class="roles-title">Manage Roles</h1>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success" role="alert">
            @TempData["Message"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger" role="alert">
            @TempData["Error"]
        </div>
    }

    <table class="table table-striped table-hover">
        <thead class="table-light">
            <tr>
                <th>Role Name</th>
                <th>Accessible Pages</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var role in Model)
            {
                <tr>
                    <td>@role.RoleName</td>
                    <td>@role.AccessiblePages</td>
                    <td>
                        <a asp-action="EditRole" asp-route-id="@role.RoleId" class="btn btn-primary">Edit</a>
                        <form asp-action="DeleteRole" asp-route-id="@role.RoleId" method="post" style="display:inline;">
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-action="CreateRole" class="btn btn-success">Add New Role</a>
</div>