@model IEnumerable<InventoryManagementWebApp.Models.UserModel>

@{
    ViewData["Title"] = "Manage Users";
}

<style>
    .users-container {
        max-width: 1000px;
        margin: 50px auto;
        padding: 30px;
        background-color: #ffffff;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .users-title {
        color: #2c3e50;
        font-size: 2.5rem;
        margin-bottom: 20px;
        font-weight: 700;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.05);
        text-align: center;
    }

    .table {
        margin-top: 20px;
    }

    .badge {
        font-size: 0.9rem;
        padding: 0.5em 0.75em;
        border-radius: 12px;
    }

    .btn {
        font-size: 0.9rem;
        padding: 0.4em 0.8em;
    }

    .alert {
        margin-bottom: 20px;
    }

    .filter-buttons {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
        justify-content: center;
    }

    .filter-buttons .btn {
        min-width: 120px;
    }
</style>

<div class="users-container">
    <h1 class="users-title">Manage Users</h1>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success" role="alert">
            @TempData["Message"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger" role="alert">
            @TempData["Error"]
        </div>
    }

    <!-- Filter Buttons -->
    <div class="filter-buttons">
        <a asp-controller="Admin" asp-action="Users" asp-route-filter="active" 
           class="btn @(ViewBag.CurrentFilter == "active" ? "btn-primary" : "btn-outline-primary")">
            Active Users
        </a>
        <a asp-controller="Admin" asp-action="Users" asp-route-filter="inactive" 
           class="btn @(ViewBag.CurrentFilter == "inactive" ? "btn-danger" : "btn-outline-danger")">
            Inactive Users
        </a>
        @* <a asp-controller="Admin" asp-action="Users" asp-route-filter="all" 
           class="btn @(ViewBag.CurrentFilter == "all" ? "btn-secondary" : "btn-outline-secondary")">
            All Users
        </a> *@
    </div>

    <div class="d-flex justify-content-end mb-3">
        <a asp-controller="Admin" asp-action="CreateUser" class="btn btn-success">Create New User</a>
    </div>

    <table class="table table-striped table-hover">
        <thead class="table-light">
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Name</th>
                <th>Active</th>
                <th>Admin</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Username</td>
                    <td>@user.Email</td>
                    <td>@user.FirstName @user.LastName</td>
                    <td>
                        <span class="badge @(user.IsActive ? "bg-success" : "bg-danger")">
                            @(user.IsActive ? "Yes" : "No")
                        </span>
                    </td>
                    <td>
                        <span class="badge @(user.IsAdmin ? "bg-info" : "bg-secondary")">
                            @(user.IsAdmin ? "Yes" : "No")
                        </span>
                    </td>
                    <td>
                        <a asp-action="EditUser" asp-route-id="@user.UserId" class="btn btn-sm btn-outline-primary">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>