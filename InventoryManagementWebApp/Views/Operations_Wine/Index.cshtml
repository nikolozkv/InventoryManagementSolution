@model InventoryManagementWebApp.Models.OperationsPageViewModel

@{
    ViewData["Title"] = "ღვინის ოპერაციები";
}

<div class="container-fluid py-4">
    <h2 class="mb-4 text-center fw-bold">ღვინის კასრზე ჩატარებული ოპერაციები</h2>
    <hr class="mb-5" />

    <div class="row gx-4">
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0 fs-5"><i class="bi bi-info-circle-fill me-2"></i> კასრის დეტალები</h5>
                </div>
                <div class="card-body">
                    <h4 class="card-title text-primary fw-bold">@Model.CompanyTypeName - @Model.CompanyName</h4>
                    <h5 class="card-text mb-0 mt-2 fs-5"><strong>ლოტი:</strong> @Model.CompanyLot</h5>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h6 class="mb-0 fs-6 fw-bold">მიმდინარე სტატუსი</h6>
                </div>
                <div class="card-body">
                    <h5 class="card-subtitle mb-3 text-muted fw-bold">კასრი: @Model.BeverageName (@(Model.HarvestYear > 0 ? Model.HarvestYear.ToString() : "უწლოვანო"))</h5>
                    <p class="card-text mb-2 fs-5">
                        <i class="bi bi-droplet-fill text-primary me-2"></i> <strong>ნაშთი:</strong> @Model.CurrentVolume ლ
                    </p>

                    @* 1. წლის პროცენტის ლოგიკა: აქვს წელი (HarvestYear > 0) და პროცენტი < 85 *@
                    <p class="card-text mb-2 d-flex align-items-center fs-5">
                        <i class="bi bi-calendar-fill text-success me-2"></i> <strong class="me-2">წლის %:</strong>
                        @if (Model.HarvestYear > 0 && Model.YearPercentage < 85 && @Model.CurrentVolume > 0)
                        {
                            <span class="text-danger fw-bold bg-danger bg-opacity-10 px-2 py-1 rounded d-inline-flex align-items-center border border-danger border-opacity-25 fs-6">
                                @Model.YearPercentage%
                                <i class="bi bi-exclamation-triangle-fill ms-2 fs-5 text-danger" title="ყურადღება! წლის პროცენტი 85%-ზე დაბალია"></i>
                            </span>
                        }
                        else
                        {
                            <span>@Model.YearPercentage%</span>
                        }
                    </p>

                    @* 2. სუფთა პროცენტის ლოგიკა: არ არის კუპაჟი და პროცენტი < 85 *@
                    <p class="card-text mb-1 d-flex align-items-center fs-5">
                        <i class="bi bi-patch-check-fill text-info me-2"></i> <strong class="me-2">სუფთა %:</strong>
                        @if (Model.SubCategory != "კუპაჟი" && Model.PurePercentage < 85 && @Model.CurrentVolume > 0)
                        {
                            <span class="text-danger fw-bold bg-danger bg-opacity-10 px-2 py-1 rounded d-inline-flex align-items-center border border-danger border-opacity-25 fs-6">
                                @Model.PurePercentage%
                                <i class="bi bi-exclamation-triangle-fill ms-2 fs-5 text-danger" title="ყურადღება! ჯიშური სასმელის სისუფთავე 85%-ზე დაბალია"></i>
                            </span>
                        }
                        else
                        {
                            <span>@Model.PurePercentage%</span>
                        }
                    </p>
                </div>
            </div>

            <div class="card shadow-sm h-md-100-flex">
                <div class="card-header bg-light">
                    <h6 class="mb-0 fs-6 fw-bold">მახასიათებლები</h6>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0 fs-5">
                        <li class="mb-2"><i class="bi bi-tag-fill text-info me-2"></i> <strong>სასმელი:</strong> @Model.ProductType</li>
                        <li class="mb-2"><i class="bi bi-bookmark-fill text-primary me-2"></i> <strong>კატეგორია:</strong> @Model.Category</li>
                        <li class="mb-2"><i class="bi bi-palette-fill text-warning me-2"></i> <strong>ფერი:</strong> @Model.Color</li>
                        <li><i class="bi bi-cup-fill text-danger me-2"></i> <strong>შაქრიანობა:</strong> @Model.Sweetness</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-8 col-md-6 mb-4">
            <div class="card h-100 shadow-sm d-flex flex-column">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0 fs-5"><i class="bi bi-plus-circle-fill me-2"></i> ახალი ოპერაცია</h5>
                </div>
                <div class="card-body overflow-auto">
                    <form asp-action="Create" method="post" id="operationForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="BarrelID" value="@Model.BarrelID" />
                        <input type="hidden" name="BeverageID" value="@Model.BeverageID" />
                        <input type="hidden" name="OperType" id="OperType" />
                        <input type="hidden" name="PreserveBarrelState" id="PreserveBarrelState" />
                        <input type="hidden" id="OperationID" name="OperationID" value="0" />

                        <script>
                            var operationDefinitionsData = @Html.Raw(Json.Serialize(ViewBag.OperationDefinitionsFull));
                        </script>

                        <div class="row g-2">
                            <div class="col-lg-6 col-md-12">
                                <div class="d-flex align-items-center mb-2">
                                    <label for="OperationDefID" class="form-label compact-label fs-6"><i class="bi bi-hand-index-thumb text-primary me-2"></i> ოპერაცია</label>
                                    <select name="OperationDefID" id="OperationDefID" class="form-select form-select-sm flex-grow-1" required>
                                        <option value="">აირჩიეთ</option>
                                        @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.OperationDefinitions)
                                        {
                                            <option value="@item.Value">@item.Text</option>
                                        }
                                    </select>
                                </div>
                                <div id="operationInfo" class="alert alert-info py-1 mb-2" style="display:none; font-size: 0.85rem;"></div>

                                <div class="d-flex align-items-center mb-2">
                                    <label for="TransactionDate" class="form-label compact-label fs-6"><i class="bi bi-calendar-date-fill text-success me-2"></i> თარიღი</label>
                                    <input type="date" name="TransactionDate" id="TransactionDate" class="form-control form-control-sm flex-grow-1" max="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                                </div>

                                <div class="d-flex align-items-center mb-2">
                                    <label for="UnitVolume" class="form-label compact-label fs-6"><i class="bi bi-droplet-half text-info me-2"></i> მოცულობა (ლ)</label>
                                    <input type="number" step="0.01" id="UnitVolume" class="form-control form-control-sm flex-grow-1" placeholder="მაგ. 0.75" />
                                </div>

                                <div class="d-flex align-items-center mb-2">
                                    <label for="BottleCount" class="form-label compact-label fs-6"><i class="bi bi-boxes text-warning me-2"></i> ცალი</label>
                                    <input type="number" id="BottleCount" class="form-control form-control-sm flex-grow-1" placeholder="მაგ. 6" />
                                </div>

                                <div class="d-flex align-items-center mb-2">
                                    <label for="Quantity" class="form-label compact-label fs-6"><i class="bi bi-clipboard-data-fill text-danger me-2"></i> სულ ლიტრი</label>
                                    <input type="number" step="0.01" name="Quantity" id="Quantity" class="form-control form-control-sm flex-grow-1" required />
                                </div>

                                <div class="d-flex align-items-center mb-2">
                                    <label for="DocumentTypeID" class="form-label compact-label fs-6"><i class="bi bi-file-earmark-text-fill text-info me-2"></i> საბუთის ტიპი</label>
                                    <div class="flex-grow-1">
                                        <select name="DocumentTypeID" id="DocumentTypeID" class="form-select form-select-sm" required>
                                            <option value="">აირჩიეთ</option>
                                            @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.DocumentTypes)
                                            {
                                                <option value="@item.Value">@item.Text</option>
                                            }
                                        </select>
                                        <span asp-validation-for="DocumentTypeID" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div class="d-flex align-items-center mb-2">
                                    <label for="DocumentNumber" class="form-label compact-label fs-6"><i class="bi bi-hash text-secondary me-2"></i> საბუთის №</label>
                                    <div class="flex-grow-1">
                                        <input type="text" name="DocumentNumber" id="DocumentNumber" class="form-control form-control-sm" required />
                                        <span asp-validation-for="DocumentNumber" class="text-danger small"></span>
                                    </div>
                                </div>

                                <div id="harvestPurityFields">
                                    @* This wrapper will be toggled by JS based on PreserveBarrelState *@
                                    <div class="d-flex align-items-center mb-2">
                                        <label for="HarvestYear" class="form-label compact-label fs-6">
                                            <i class="bi bi-calendar-check-fill text-success me-2"></i> მოსავლის წელი
                                        </label>
                                        <input type="number"
                                               name="HarvestYear"
                                               id="HarvestYear"
                                               class="form-control form-control-sm flex-grow-1"
                                               list="vintageYears"
                                               placeholder="შეიყვანეთ ან აირჩიეთ"
                                               maxlength="4"
                                               max="@DateTime.Now.Year"
                                               min="1900"
                                               value="@(Model.HarvestYear > 0 ? Model.HarvestYear.ToString() : "")"
                                               oninput="if(this.value.length > 4) this.value = this.value.slice(0, 4);" />

                                        <datalist id="vintageYears">
                                            @if (ViewBag.VintageYears != null)
                                            {
                                                @foreach (var y in (List<int>)ViewBag.VintageYears)
                                                {
                                                    <option value="@y"></option>
                                                }
                                            }
                                        </datalist>
                                    </div>

                                    <div class="d-flex align-items-center mb-2">
                                        <label for="YearAPercentInput" class="form-label compact-label fs-6"><i class="bi bi-percent text-primary me-2"></i> წლის %</label>
                                        <select name="YearAPercent" id="YearAPercentInput" class="form-select form-select-sm flex-grow-1">
                                            <option value="">აირჩიე %</option>
                                            @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.PercentList)
                                            {
                                                <option value="@item.Value">@item.Text</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="d-flex align-items-center mb-2">
                                        <label for="PureAPercentInput" class="form-label compact-label fs-6"><i class="bi bi-percent text-primary me-2"></i> სუფთა %</label>
                                        <select name="PureAPercent" id="PureAPercentInput" class="form-select form-select-sm flex-grow-1">
                                            <option value="">აირჩიე %</option>
                                            @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.PercentList)
                                            {
                                                <option value="@item.Value">@item.Text</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-6 col-md-12">
                                <div id="companyBarrelFields" style="display:none;">
                                    @* Initial state is hidden *@
                                    <div class="d-flex align-items-center mb-2">
                                        <label for="CompanySearch" class="form-label compact-label fs-6"><i class="bi bi-search text-secondary me-2"></i> კომპანიის ძიება</label>
                                        <input type="text" id="CompanySearch" class="form-control form-control-sm flex-grow-1" placeholder="ჩაწერე კომპანიის სახელი" disabled />
                                    </div>

                                    <div class="d-flex align-items-center mb-2">
                                        <label for="OppositeCompanyID" class="form-label compact-label fs-6"><i class="bi bi-building text-primary me-2"></i> კომპანია</label>
                                        <select name="OppositeCompanyID" id="OppositeCompanyID" class="form-select form-select-sm flex-grow-1" disabled>
                                            <option value="">აირჩიეთ კომპანია</option>
                                        </select>
                                    </div>

                                    <div class="d-flex align-items-center mb-2">
                                        <label for="BarrelSearch" class="form-label compact-label fs-6"><i class="bi bi-search text-secondary me-2"></i> კასრის ძიება</label>
                                        <input type="text" id="BarrelSearch" class="form-control form-control-sm flex-grow-1" placeholder="ჩაწერე კასრის სახელი ან წელი" disabled />
                                    </div>

                                    <div class="d-flex align-items-center mb-2">
                                        <label for="OppositeBarrelID" class="form-label compact-label fs-6"><i class="bi bi-barrel-fill text-warning me-2"></i> კასრი</label>
                                        <select id="OppositeBarrelID" name="OppositeBarrelID" class="form-select form-select-sm flex-grow-1" disabled></select>
                                    </div>
                                </div>

                                <div id="beverageCharacteristicsFields">
                                    @* This wrapper will be always visible *@
                                    <div class="d-flex align-items-center mb-2">
                                        <label for="bevName" class="form-label compact-label fs-6"><i class="bi bi-star-fill text-warning me-2"></i> სასმელი</label>
                                        <input type="text" id="bevName" class="form-control form-control-sm flex-grow-1" readonly />
                                    </div>

                                    <div class="d-flex align-items-center mb-2">
                                        <label for="bevType" class="form-label compact-label fs-6"><i class="bi bi-tags-fill text-info me-2"></i> ტიპი</label>
                                        <input type="text" id="bevType" class="form-control form-control-sm flex-grow-1" readonly />
                                    </div>

                                    <div class="d-flex align-items-center mb-2">
                                        <label for="bevCategory" class="form-label compact-label fs-6"><i class="bi bi-list-nested text-info me-2"></i> კატეგორია</label>
                                        <input type="text" id="bevCategory" class="form-control form-control-sm flex-grow-1" readonly />
                                    </div>

                                    <div class="d-flex align-items-center mb-2">
                                        <label for="bevColor" class="form-label compact-label fs-6"><i class="bi bi-palette-fill text-info me-2"></i> ფერი</label>
                                        <input type="text" id="bevColor" class="form-control form-control-sm flex-grow-1" readonly />
                                    </div>

                                    <div class="d-flex align-items-center mb-2">
                                        <label for="bevSweetness" class="form-label compact-label fs-6"><i class="bi bi-cake-fill text-danger me-2"></i> შაქრიანობა</label>
                                        <input type="text" id="bevSweetness" class="form-control form-control-sm flex-grow-1" readonly />
                                    </div>
                                </div>

                                <div class="d-flex align-items-center mb-2">
                                    <label for="VolumeBefore" class="form-label compact-label fs-6"><i class="bi bi-box-fill text-secondary me-2"></i> მოცულობა თარიღისთვის</label>
                                    <input type="text" id="VolumeBefore" class="form-control form-control-sm flex-grow-1 fw-bold" readonly />
                                </div>

                                <div class="d-flex align-items-center mb-2">
                                    <label for="YearPercentReadOnly" class="form-label compact-label fs-6"><i class="bi bi-calendar-fill text-success me-2"></i> წლის % (თარიღისთვის)</label>
                                    <input type="number" id="YearPercentReadOnly" class="form-control form-control-sm flex-grow-1" readonly />
                                </div>

                                <div class="d-flex align-items-center mb-2">
                                    <label for="PurePercentReadOnly" class="form-label compact-label fs-6"><i class="bi bi-patch-check-fill text-primary me-2"></i> სუფთა % (თარიღისთვის)</label>
                                    <input type="number" id="PurePercentReadOnly" class="form-control form-control-sm flex-grow-1" readonly />
                                </div>

                                <div id="limitFields" style="display:none;">
                                    <div class="d-flex align-items-center mb-2">
                                        <label for="YearLimit" class="form-label compact-label fs-6"><i class="bi bi-speedometer2 text-danger me-2"></i> წლის ლიმიტი</label>
                                        <input type="text" id="YearLimit" class="form-control form-control-sm flex-grow-1 border-danger text-danger fw-bold" readonly />
                                    </div>

                                    <div class="d-flex align-items-center mb-2">
                                        <label for="PureLimit" class="form-label compact-label fs-6"><i class="bi bi-thermometer-half text-danger me-2"></i> სისუფთავის ლიმიტი</label>
                                        <input type="text" id="PureLimit" class="form-control form-control-sm flex-grow-1 border-danger text-danger fw-bold" readonly />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-light d-flex justify-content-between p-3 sticky-bottom-custom">
                    <div class="d-flex gap-4">

                        @* --- გამყოფი ხაზი (ვიზუალური დაშორებისთვის) --- *@
                        <div class="vr mx-5"></div>

                        <button type="submit" class="btn btn-success btn-lg" id="AddButton" form="operationForm">
                            <i class="bi bi-plus-circle-fill me-2"></i> დამატება
                        </button>

                        @* --- გამყოფი ხაზი (ვიზუალური დაშორებისთვის) --- *@
                        <div class="vr mx-2"></div>

                        <button type="button" class="btn btn-info btn-lg" id="LoadFromClipboardBtn">
                            <i class="bi bi-clipboard-check me-2"></i> ჩატვირთვა
                        </button>
                    </div>
                    <a asp-controller="CompanyBarrelDetails" asp-action="Index" asp-route-companyId="@Model.CompanyID"
                           class="btn btn-secondary btn-lg">
                        <i class="bi bi-arrow-left-circle-fill me-2"></i> უკან
                    </a>
                </div>
            </div>
        </div>
    </div>

    <h3 class="mb-3 mt-5 fw-bold"><i class="bi bi-clock-history text-primary me-2"></i> ოპერაციების ისტორია</h3>
    @if (Model.Operations?.Any() == true)
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead class="table-light">
                    <tr>
                        <th class="fs-6 py-2">თარიღი</th>
                        <th class="fs-6 py-2">საბუთი</th>
                        <th class="fs-6 py-2">№</th>
                        <th class="fs-6 py-2">სახელი</th>
                        <th class="fs-6 py-2">წელი</th>
                        <th class="fs-6 py-2">წლის %</th>
                        <th class="fs-6 py-2">სუფთა %</th>
                        <th class="fs-6 py-2">ტიპი</th>
                        <th class="fs-6 py-2">კატეგ.</th>
                        <th class="fs-6 py-2">ფერი</th>
                        <th class="fs-6 py-2">შაქრიანობა</th>
                        <th class="fs-6 py-2">ლიტრი</th>
                        <th class="fs-6 py-2">ოპერაცია</th>
                        <th class="fs-6 py-2">ნაშთი</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var op in Model.Operations)
                    {
                        var rowClass = "";
                        if (op.Quantity.StartsWith("-"))
                        {
                            rowClass = "table-danger";
                        }
                        @* else if (op.BeverageName != Model.BeverageName || op.HarvestYear != Model.HarvestYear)
                        {
                            rowClass = "table-warning";
                        } *@
                        else
                        {
                            rowClass = "table-success";
                        }

                        <tr class="@rowClass">
                            <td>@op.TransactionDate.ToString("yyyy-MM-dd")</td>
                            <td>@op.DocumentTypeName</td>
                            <td>@op.DocumentNumber</td>
                            <td>
                                @op.BeverageName
                                <div style="text-align: right; font-size: small; font-weight: bold; color: black;">
                                    @op.ExecutedByUserFullName
                                </div>
                            </td>
                            <td>@op.HarvestYear</td>
                            <td>@op.YearPercentage</td>
                            <td>@op.PurePercentage</td>
                            <td>@op.ProductType</td>
                            <td>@op.Category</td>
                            <td>@op.Color</td>
                            <td>@op.Sweetness</td>
                            <td class="fw-bold fs-6">@op.Quantity</td>
                            <td>
                                @op.OperName
                                @* --- ახალი დამატებული კოდი კასრის ლინკისთვის --- *@
                                @if (!string.IsNullOrEmpty(op.SourceCompanyName) & (op.SourceBarrelID != null))
                                {
                                    <div style="text-align: left; font-size: small; font-weight: bold; color: black;">
                                        <a href="@Url.Action("Index", "Operations", new { barrelId = op.SourceBarrelID })"
                                            @* class="badge bg-primary text-white text-decoration-none p-2" *@
                                               title="გადასვლა დაკავშირებულ კასრზე">
                                            <i class="bi bi-box-arrow-up-right text-primary me-1"></i> @op.SourceCompanyName: #@op.SourceBarrelID
                                        </a>
                                    </div>
                                }
                            </td>
                            <td class="fw-bold">@op.VolumeLeft</td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    @* <button type="button" class="btn btn-warning btn-sm" onclick="editOperation(@op.OperationID)" title="რედაქტირება">
                                        <i class="bi bi-pencil-fill"></i>
                                    </button> *@

                                    <form asp-action="Delete" method="post" asp-controller="Operations_Wine" class="delete-form">
                                        <input type="hidden" name="operationId" value="@op.OperationID" />
                                        <button type="submit" class="btn btn-danger btn-sm" title="წაშლა">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i> ოპერაციები ვერ იქნა ნაპოვნი.
        </div>
    }
</div>

@section Scripts {
    <style>
        /* Custom CSS for sticky footer in card */
        .card.d-flex.flex-column {
            min-height: 500px;
        }

        .card-body.overflow-auto {
            flex-grow: 1;
        }

        .sticky-bottom-custom {
            position: sticky;
            bottom: 0;
            z-index: 10;
        }

        /* Responsive adjustments for the info section characteristics card */
        @@media (min-width: 768px) {
            .col-lg-4.col-md-6 {
                display: flex;
                flex-direction: column;
            }

                .col-lg-4.col-md-6 .card:last-child {
                    flex-grow: 1;
                }
        }

        /* --- New styles for labels next to inputs --- */
        .compact-label {
            width: 140px;
            flex-shrink: 0;
            margin-right: 0.5rem;
            text-align: right;
            margin-bottom: 0 !important;
            font-size: 0.875rem;
        }

        /* Adjustments for inputs themselves */
        .form-control-sm, .form-select-sm {
            height: calc(1.8125rem + 2px);
            padding: 0.25rem 0.5rem;
            font-size: 0.875rem;
        }

        /* Adjust alert padding */
        #operationInfo.alert {
            padding-top: 0.4rem;
            padding-bottom: 0.4rem;
            margin-bottom: 0.5rem !important;
        }

        /* Adjust margin-bottom for the d-flex containers */
        .d-flex.align-items-center.mb-2 {
            margin-bottom: 0.5rem !important;
        }

        /* Styles for table with sticky header and horizontal scroll */
        .table-responsive {
            max-height: 500px;
            overflow-y: auto;
            overflow-x: auto;
            width: 100%;
        }

            .table-responsive .table td,
            .table-responsive .table th {
                white-space: nowrap;
            }

        .table thead th {
            position: sticky;
            top: 0;
            background-color: var(--bs-table-bg, #f8f9fa);
            z-index: 2;
            box-shadow: 0 2px 2px -1px rgba(0, 0, 0, 0.1);
        }

        .table th:last-child,
        .table td:last-child {
            position: sticky;
            right: 0;
            background-color: var(--bs-table-bg, #f8f9fa);
            z-index: 1;
            box-shadow: -2px 0 5px rgba(0,0,0,0.05);
        }

        .table thead th:last-child {
            z-index: 3;
        }

        /* NEW: Style for readonly inputs */
        input[readonly].form-control,
        select[readonly].form-control {
            background-color: #e9ecef;
            opacity: 1;
            cursor: default;
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function () {

            // Cache DOM elements
            const companySearchInput = document.getElementById('CompanySearch');
            const oppositeCompanySelect = document.getElementById('OppositeCompanyID');
            const barrelSearchInput = document.getElementById('BarrelSearch');
            const oppositeBarrelSelect = document.getElementById('OppositeBarrelID');
            const operationDefSelect = document.getElementById('OperationDefID');
            const operationInfoBox = document.getElementById('operationInfo');
            const operTypeInput = document.getElementById('OperType');
            const preserveBarrelStateInput = document.getElementById('PreserveBarrelState');
            const unitVolumeInput = document.getElementById('UnitVolume');
            const bottleCountInput = document.getElementById('BottleCount');
            const quantityInput = document.getElementById('Quantity');
            const transactionDateInput = document.getElementById('TransactionDate');
            const volumeBeforeInput = document.getElementById('VolumeBefore');
            const beverageIdInput = document.querySelector('[name="BeverageID"]');
            const bevNameInput = document.getElementById('bevName');
            const bevTypeInput = document.getElementById('bevType');
            const bevCategoryInput = document.getElementById('bevCategory');
            const bevColorInput = document.getElementById('bevColor');
            const bevSweetnessInput = document.getElementById('bevSweetness');
            const yearPercentReadOnlyInput = document.getElementById('YearPercentReadOnly');
            const purePercentReadOnlyInput = document.getElementById('PurePercentReadOnly');
            const yearLimitInput = document.getElementById('YearLimit');
            const pureLimitInput = document.getElementById('PureLimit');
            const addButton = document.getElementById('AddButton');
            const harvestYearInput = document.getElementById('HarvestYear');
            const yearAPercentInput = document.getElementById('YearAPercentInput');
            const pureAPercentInput = document.getElementById('PureAPercentInput');

            // Sections to dynamically show/hide
            const companyBarrelFields = document.getElementById('companyBarrelFields');
            const harvestPurityFields = document.getElementById('harvestPurityFields');
            const limitFields = document.getElementById('limitFields');


            // --- Helper Functions ---

            function filterDropdown(inputElement, selectElement) {
                const filter = inputElement.value.toLowerCase();
                Array.from(selectElement.options).forEach(opt => {
                    const txt = opt.text.toLowerCase();
                    opt.style.display = txt.includes(filter) ? 'block' : 'none';
                });
            }

            function updateQuantityFromPieces() {
                const unitVolume = parseFloat(unitVolumeInput.value);
                const bottleCount = parseFloat(bottleCountInput.value);

                if (!isNaN(unitVolume) && !isNaN(bottleCount)) {
                    quantityInput.value = (unitVolume * bottleCount).toFixed(2);
                } else {
                    quantityInput.value = '';
                }
            }

            async function updateVolumeByDate() {
                const operType = operTypeInput.value;
                const barrelId = @Model.BarrelID;
                const oppositeBarrelId = oppositeBarrelSelect.value;
                const date = transactionDateInput.value;

                // Clear beverage data and read-only fields first
                beverageIdInput.value = "";
                bevNameInput.value = "";
                bevTypeInput.value = "";
                bevCategoryInput.value = "";
                bevColorInput.value = "";
                bevSweetnessInput.value = "";
                volumeBeforeInput.value = "";
                yearPercentReadOnlyInput.value = "";
                purePercentReadOnlyInput.value = "";
                yearLimitInput.value = "";
                pureLimitInput.value = "";
                addButton.disabled = true;

                if (!operType || !barrelId || !date) {
                    return;
                }

                if ((operType == 2 || operType == 4) && !oppositeBarrelId) {
                     return;
                }
                if (operType == 3 && (!oppositeCompanySelect.value || !oppositeBarrelId)) {
                    return;
                }

                const url = `/api/operations-wine/get-data-by-transdate?operType=${operType}&barrelId=${barrelId}&oppositeBarrelId=${oppositeBarrelId}&transactionDate=${date}`;

                try {
                    const response = await fetch(url);
                    if (!response.ok) {
                        throw new Error(`HTTP error! status: ${response.status}`);
                    }
                    const data = await response.json();

                    volumeBeforeInput.value = data.volume?.toFixed(2) + " ლ" ?? "";
                    beverageIdInput.value = data.beverageId || "";
                    bevNameInput.value = data.beverageName || "";
                    bevTypeInput.value = data.productType || "";
                    bevCategoryInput.value = data.category || "";
                    bevColorInput.value = data.color || "";
                    bevSweetnessInput.value = data.sweetness || "";
                    yearPercentReadOnlyInput.value = data.yearPercent ?? "";
                    purePercentReadOnlyInput.value = data.purePercent ?? "";

                    if (data.yearLimit === -1) {
                            yearLimitInput.value = "ლიმიტის გარეშე";
                        } else {
                            yearLimitInput.value = data.yearLimit ?? "";
                        }

                    if (data.pureLimit === -1) {
                            pureLimitInput.value = "ლიმიტის გარეშე";
                        } else {
                            pureLimitInput.value = data.pureLimit ?? "";
                        }

                    addButton.disabled = !data.allowMix;
                    } catch (error) {
                        console.error("Error fetching volume data:", error);
                        volumeBeforeInput.value = "შეცდომა";
                        yearLimitInput.value = "";
                        pureLimitInput.value = "";
                        addButton.disabled = true;
                    }
                }

            function toggleHarvestPurityFields() {
                const preserve = preserveBarrelStateInput.value;
                const isDisabled = (preserve === "1" || preserve?.toLowerCase() === "true");

                harvestYearInput.disabled = isDisabled;
                yearAPercentInput.disabled = isDisabled;
                pureAPercentInput.disabled = isDisabled;

                if (isDisabled) {
                    harvestPurityFields.style.display = 'none';
                } else {
                    harvestPurityFields.style.display = 'block';

                    if (!harvestYearInput.value) {
                        harvestYearInput.value = harvestYearInput.defaultValue;
                    }

                    if (!yearAPercentInput.value) {
                        yearAPercentInput.value = '100';
                    }
                    if (!pureAPercentInput.value) {
                        pureAPercentInput.value = '100';
                    }
                }
            }

            function toggleLimitFields() {
                const operType = operTypeInput.value;
                if (operType == 2 || operType == 3 || operType == 4) {
                    limitFields.style.display = 'block';
                } else {
                    limitFields.style.display = 'none';
                    yearLimitInput.value = '';
                    pureLimitInput.value = '';
                }
            }

            async function handleCompanyBarrelFields() {
                const operType = operTypeInput.value;

                // Reset all company/barrel related fields
                oppositeCompanySelect.innerHTML = '<option value="">აირჩიეთ კომპანია</option>';
                oppositeCompanySelect.disabled = true;
                companySearchInput.disabled = true;
                companySearchInput.value = '';

                oppositeBarrelSelect.innerHTML = '';
                oppositeBarrelSelect.disabled = true;
                barrelSearchInput.disabled = true;
                barrelSearchInput.value = '';

                if (operType == 3) {
                    companyBarrelFields.style.display = 'block';
                    oppositeCompanySelect.disabled = false;
                    companySearchInput.disabled = false;

                    try {
                        const response = await fetch(`/api/operations-wine/filtered-companies?barrelId=${@Model.BarrelID}`);
                        const companies = await response.json();
                        companies.forEach(c => {
                            oppositeCompanySelect.innerHTML += `<option value="${c.value}">${c.text}</option>`;
                        });
                    } catch (error) {
                        console.error("Error fetching companies:", error);
                    }

                } else if (operType == 2 || operType == 4) {
                    companyBarrelFields.style.display = 'block';
                    oppositeBarrelSelect.disabled = false;
                    barrelSearchInput.disabled = false;

                    try {
                        const response = await fetch(`/api/operations-wine/filtered-barrels?barrelId=${@Model.BarrelID}&operType=${operType}`);
                        const barrels = await response.json();
                        barrels.forEach(b => {
                            oppositeBarrelSelect.innerHTML += `<option value="${b.value}">${b.text}</option>`;
                        });
                    } catch (error) {
                        console.error("Error fetching barrels for OperType 2/4:", error);
                    }
                } else {
                    companyBarrelFields.style.display = 'none';
                }
                updateVolumeByDate();
            }


            // --- Event Listeners ---

            companySearchInput.addEventListener('input', () => filterDropdown(companySearchInput, oppositeCompanySelect));
            barrelSearchInput.addEventListener('input', () => filterDropdown(barrelSearchInput, oppositeBarrelSelect));

            unitVolumeInput.addEventListener('input', updateQuantityFromPieces);
            bottleCountInput.addEventListener('input', updateQuantityFromPieces);

            operationDefSelect.addEventListener('change', async function () {
                const selectedId = this.value;
                if (!selectedId) {
                    operationInfoBox.style.display = 'none';
                    operTypeInput.value = '';
                    preserveBarrelStateInput.value = '';
                    handleCompanyBarrelFields();
                    toggleHarvestPurityFields();
                    toggleLimitFields();
                    updateVolumeByDate();
                    return;
                }

                const selected = operationDefinitionsData.find(o => o.operationDefID == selectedId);
                if (selected) {
                    operTypeInput.value = selected.operType;
                    preserveBarrelStateInput.value = selected.preserveBarrelState;

                    await handleCompanyBarrelFields();
                    toggleHarvestPurityFields();
                    toggleLimitFields();
                    updateVolumeByDate();
                }
            });

            oppositeCompanySelect.addEventListener('change', async function () {
                const companyId = this.value;
                oppositeBarrelSelect.innerHTML = '';
                oppositeBarrelSelect.disabled = true;
                barrelSearchInput.disabled = true;
                barrelSearchInput.value = '';

                if (!companyId) {
                    updateVolumeByDate();
                    return;
                }

                try {
                    const response = await fetch(`/api/operations-wine/filtered-barrels?barrelId=${@Model.BarrelID}&operType=3&companyId=${companyId}`);
                    const barrels = await response.json();
                    barrels.forEach(b => {
                        oppositeBarrelSelect.innerHTML += `<option value="${b.value}">${b.text}</option>`;
                    });
                    oppositeBarrelSelect.disabled = false;
                    barrelSearchInput.disabled = false;
                } catch (error) {
                    console.error("Error fetching barrels for company:", error);
                }
                updateVolumeByDate();
            });

            oppositeBarrelSelect.addEventListener('change', updateVolumeByDate);
            transactionDateInput.addEventListener('change', updateVolumeByDate);

            // Initial calls on page load
            handleCompanyBarrelFields();
            toggleHarvestPurityFields();
            toggleLimitFields();
            updateVolumeByDate();

            // ----------------------------------------------------
            // შეცდომისას ფორმის მონაცემების აღდგენა (მხოლოდ ამ გვერდისთვის)
            const formDataJson = @Html.Raw(Json.Serialize(TempData["FormData"]?.ToString() ?? ""));

            // ფორმის აღდგენის ფუნქცია
            function restoreFormData() {
                if (formDataJson && formDataJson !== "") {
                    try {
                        const formData = JSON.parse(formDataJson);
                        console.log('Restoring form data:', formData);

                        if (formData.OperationDefID) {
                            operationDefSelect.value = formData.OperationDefID;
                            const changeEvent = new Event('change');
                            operationDefSelect.dispatchEvent(changeEvent);
                            
                            setTimeout(() => {
                                restoreOtherFields(formData);
                            }, 500);
                        } else {
                            restoreOtherFields(formData);
                        }
                    } catch (error) {
                        console.error('Error restoring form data:', error);
                    }
                }
            }

            function restoreOtherFields(formData) {
                if (formData.TransactionDate) {
                    transactionDateInput.value = formData.TransactionDate.split('T')[0];
                    transactionDateInput.dispatchEvent(new Event('change'));
                }
                if (formData.Quantity) quantityInput.value = formData.Quantity;
                if (formData.DocumentTypeID && document.getElementById('DocumentTypeID')) {
                    document.getElementById('DocumentTypeID').value = formData.DocumentTypeID;
                }
                if (formData.DocumentNumber && document.getElementById('DocumentNumber')) {
                    document.getElementById('DocumentNumber').value = formData.DocumentNumber;
                }
                if (formData.HarvestYear) harvestYearInput.value = formData.HarvestYear;
                if (formData.YearAPercent) yearAPercentInput.value = formData.YearAPercent;
                if (formData.PureAPercent) pureAPercentInput.value = formData.PureAPercent;
                
                if (formData.OppositeCompanyID && oppositeCompanySelect) {
                    oppositeCompanySelect.value = formData.OppositeCompanyID;
                    oppositeCompanySelect.dispatchEvent(new Event('change'));
                    
                    if (formData.OppositeBarrelID) {
                        setTimeout(() => {
                            if (oppositeBarrelSelect) {
                                oppositeBarrelSelect.value = formData.OppositeBarrelID;
                                oppositeBarrelSelect.dispatchEvent(new Event('change'));
                            }
                        }, 1000);
                    }
                } else if (formData.OppositeBarrelID && oppositeBarrelSelect) {
                    setTimeout(() => {
                        oppositeBarrelSelect.value = formData.OppositeBarrelID;
                        oppositeBarrelSelect.dispatchEvent(new Event('change'));
                    }, 500);
                }

                if (formData.Quantity && !unitVolumeInput.value && !bottleCountInput.value) {
                    const qty = parseFloat(formData.Quantity);
                    if (qty <= 1) {
                        unitVolumeInput.value = qty.toString();
                        bottleCountInput.value = "1";
                    } else if (qty <= 10) {
                        unitVolumeInput.value = "0.75";
                        bottleCountInput.value = Math.round(qty / 0.75).toString();
                    } else {
                        unitVolumeInput.value = "1";
                        bottleCountInput.value = qty.toString();
                    }
                }
            }

            // ვიძახებთ მონაცემების აღდგენას პირდაპირ (თუ არსებობს)
            restoreFormData();

            // ----------------------------------------------------
            // F1 Clipboard ლოგიკა
            const loadFromClipboardBtn = document.getElementById('LoadFromClipboardBtn');
            const documentTypeSelect = document.getElementById('DocumentTypeID');
            const documentNumberInput = document.getElementById('DocumentNumber');
            
            if (loadFromClipboardBtn) {
                loadFromClipboardBtn.addEventListener('click', function() {
                    try {
                        console.log('Loading clipboard data...');
                        const clipboardData = window.getClipboardData ? window.getClipboardData() : {};
                        let fieldsLoaded = 0;
                        
                        // Load საბუთი
                        if (clipboardData.sabuti && documentTypeSelect) {
                            if (clipboardData.sabuti) {
                                documentTypeSelect.value = clipboardData.sabuti;
                                if (documentTypeSelect.value) fieldsLoaded++;
                            }
                            
                            if (!documentTypeSelect.value && clipboardData.sabutiText) {
                                const sabutiText = clipboardData.sabutiText.toLowerCase().trim();
                                const options = Array.from(documentTypeSelect.options);
                                const matchedOption = options.find(option =>
                                    option.text.toLowerCase().includes(sabutiText) ||
                                    sabutiText.includes(option.text.toLowerCase())
                                );
                                if (matchedOption) {
                                    documentTypeSelect.value = matchedOption.value;
                                    fieldsLoaded++;
                                }
                            }
                        }
                        
                        // Load N
                        if (clipboardData.number && documentNumberInput) {
                            documentNumberInput.value = clipboardData.number;
                            fieldsLoaded++;
                        }
                        
                        // Load თარიღი
                        if (clipboardData.date && transactionDateInput) {
                            transactionDateInput.value = clipboardData.date;
                            fieldsLoaded++;
                            transactionDateInput.dispatchEvent(new Event('change'));
                        }
                        
                        if (fieldsLoaded > 0) {
                            loadFromClipboardBtn.innerHTML = '<i class="bi bi-check-circle me-2"></i> ჩაიტვირთა';
                            loadFromClipboardBtn.classList.replace('btn-info', 'btn-success');
                            setTimeout(() => {
                                loadFromClipboardBtn.innerHTML = '<i class="bi bi-clipboard-check me-2"></i> ჩატვირთვა';
                                loadFromClipboardBtn.classList.replace('btn-success', 'btn-info');
                            }, 1000);
                        } else {
                            loadFromClipboardBtn.innerHTML = '<i class="bi bi-exclamation-triangle me-2"></i> ცარიელია';
                            loadFromClipboardBtn.classList.replace('btn-info', 'btn-warning');
                            setTimeout(() => {
                                loadFromClipboardBtn.innerHTML = '<i class="bi bi-clipboard-check me-2"></i> ჩატვირთვა';
                                loadFromClipboardBtn.classList.replace('btn-warning', 'btn-info');
                            }, 1000);
                        }
                    } catch (error) {
                        console.error('Error loading clipboard data:', error);
                        loadFromClipboardBtn.innerHTML = '<i class="bi bi-x-circle me-2"></i> შეცდომა';
                        loadFromClipboardBtn.classList.replace('btn-info', 'btn-danger');
                        setTimeout(() => {
                            loadFromClipboardBtn.innerHTML = '<i class="bi bi-clipboard-check me-2"></i> ჩატვირთვა';
                            loadFromClipboardBtn.classList.replace('btn-danger', 'btn-info');
                        }, 2000);
                    }
                });
            }

        }); // DOMContentLoaded იხურება აქ

        // ============================================================
        // ✅ გლობალური ფუნქციები (უნდა იყოს DOMContentLoaded-ის გარეთ)
        // ============================================================
        
        function editOperation(id) {
            console.log("Edit clicked for ID:", id);

            fetch('/Operations_Wine/GetOperationForEdit?id=' + id)
                .then(res => {
                    if (!res.ok) throw new Error("მონაცემები ვერ მოიძებნა (Check Network Tab)");
                    return res.json();
                })
                .then(data => {
                    console.log("Received data:", data);

                    document.getElementById('OperationID').value = data.operationID;
                    document.getElementById('TransactionDate').value = data.transactionDate;
                    document.getElementById('Quantity').value = data.quantity;
                    document.getElementById('DocumentNumber').value = data.documentNumber || '';
                    
                    if(document.getElementById('HarvestYear'))
                        document.getElementById('HarvestYear').value = data.harvestYear;

                    if(document.getElementById('BeverageID'))
                         document.getElementById('BeverageID').value = data.beverageID;

                    const opSelect = document.getElementById('OperationDefID');
                    if(opSelect) {
                        opSelect.value = data.operationDefID;
                        opSelect.dispatchEvent(new Event('change'));
                    }

                    if (data.sourceBarrelID) {
                        setTimeout(() => {
                            const srcBarrel = document.getElementById('OppositeBarrelID');
                            if (srcBarrel) srcBarrel.value = data.sourceBarrelID;
                        }, 500);
                    }

                    const form = document.getElementById('operationForm');
                    form.action = '/Operations/UpdateOperation';

                    const btn = document.getElementById('AddButton');
                    btn.innerHTML = '<i class="bi bi-save"></i> შენახვა';
                    btn.classList.remove('btn-success');
                    btn.classList.add('btn-warning');

                    if (!document.getElementById('btnCancelEdit')) {
                        const cancelBtn = document.createElement('button');
                        cancelBtn.type = 'button';
                        cancelBtn.id = 'btnCancelEdit';
                        cancelBtn.className = 'btn btn-secondary btn-lg ms-2';
                        cancelBtn.innerText = 'გაუქმება';
                        cancelBtn.onclick = resetForm;
                        btn.parentNode.appendChild(cancelBtn);
                    }
                    
                    document.querySelector('.card-header.bg-primary').scrollIntoView({ behavior: 'smooth' });
                })
                .catch(err => {
                    console.error(err);
                    alert("შეცდომა მონაცემების წამოღებისას: " + err.message);
                });
        }

        function resetForm() {
            const form = document.getElementById('operationForm');
            form.reset();
            document.getElementById('OperationID').value = "0";
            
            form.action = '/Operations/AddOperation';
            
            const btn = document.getElementById('AddButton');
            btn.innerHTML = '<i class="bi bi-plus-circle-fill me-2"></i> დამატება';
            btn.classList.remove('btn-warning');
            btn.classList.add('btn-success');
            
            const cancel = document.getElementById('btnCancelEdit');
            if (cancel) cancel.remove();
            
            const opSelect = document.getElementById('OperationDefID');
            if(opSelect) opSelect.dispatchEvent(new Event('change'));
        }
    </script>
}