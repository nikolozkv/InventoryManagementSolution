@model OperationDefinition

@{
    ViewData["Title"] = "✏️ ოპერაციის განსაზღვრის რედაქტირება";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-info text-white p-3 rounded-top-3 d-flex align-items-center justify-content-center">
                    <h2 class="card-title mb-0 fs-3">
                        <i class="bi bi-pencil-square me-2 fs-4"></i>
                        <span class="fw-bold">@ViewData["Title"]</span>
                    </h2>
                </div>
                <div class="card-body p-4">
                    <form asp-action="@(Model.OperationDefID == 0 ? "Create" : "Edit")" method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="OperationDefID" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold">
                                <i class="bi bi-tag-fill me-1"></i> სახელი:
                            </label>
                            <input asp-for="Name" class="form-control form-control-lg" placeholder="მაგ: დამატება" />
                            <span asp-validation-for="Name" class="text-danger small mt-1"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Math" class="form-label fw-semibold">
                                <i class="bi bi-calculator-fill me-1"></i> არითმეტიკა:
                            </label>
                            <select asp-for="Math" class="form-select form-select-lg" asp-items="ViewBag.MathOptions">
                                <option value="">-- აირჩიე არითმეტიკა --</option>
                            </select>
                            <span asp-validation-for="Math" class="text-danger small mt-1"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="OperType" class="form-label fw-semibold">
                                <i class="bi bi-boxes me-1"></i> ოპერაციის ტიპი:
                            </label>
                            <select asp-for="OperType" class="form-select form-select-lg" asp-items="ViewBag.OperTypeOptions">
                                <option value="">-- აირჩიე ოპერაციის ტიპი --</option>
                            </select>
                            <span asp-validation-for="OperType" class="text-danger small mt-1"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NameOpposite" class="form-label fw-semibold">
                                <i class="bi bi-arrow-left-right me-1"></i> საპირისპირო სახელი:
                            </label>
                            <input asp-for="NameOpposite" class="form-control form-control-lg" placeholder="მაგ: (-) კომპანიაზე გაყიდვა (საჭიროა თუ ოპერაციის ტიპი > 1)" />
                            <span asp-validation-for="NameOpposite" class="text-danger small mt-1"></span>
                        </div>

                        <div class="mb-4">
                            @* Changed mb-3 to mb-4 for more space before next section *@
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" role="switch" id="PreserveBarrelState" asp-for="PreserveBarrelState">
                                <label class="form-check-label fw-semibold" for="PreserveBarrelState">
                                    <i class="bi bi-stack-fill me-1"></i> შენარჩუნდეს სასმელის მდგომარეობა
                                </label>
                                <div id="preserveBarrelHelp" class="form-text text-muted">მონიშნეთ თუ ამ ოპერაციით არ იცვლება სასმელის მდგომარეობა (მაგ. წლის %).</div>
                            </div>
                            <span asp-validation-for="PreserveBarrelState" class="text-danger fs-6 mt-1 d-block"></span>
                        </div>


                        <div class="d-flex justify-content-center flex-wrap gap-3 pt-3 border-top mt-4">
                            <button type="submit" class="btn btn-success btn-lg px-4" title="შენახვა">
                                <i class="bi bi-save-fill me-2"></i> 💾 შენახვა
                            </button>
                            <a asp-action="Index" class="btn btn-secondary btn-lg px-4" title="დაბრუნება">
                                <i class="bi bi-arrow-left-circle-fill me-2"></i> 🔙 დაბრუნება
                            </a>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-light p-4 rounded-bottom-3">
                    <h5 class="fw-bold mb-3 text-primary">
                        <i class="bi bi-info-circle-fill me-2"></i> 🧾 სახელმძღვანელო
                    </h5>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item bg-light border-0 px-0 py-2">
                            <strong class="text-dark">არითმეტიკა:</strong>
                            <span class="text-muted"><code>(+)</code> = გაზრდა, <code>(-)</code> = შემცირება</span>
                        </li>
                        <li class="list-group-item bg-light border-0 px-0 py-2">
                            <strong class="text-dark">ოპერაციის ტიპი:</strong>
                            <ul class="list-unstyled ms-3 mt-2">
                                <li class="text-muted"><i class="bi bi-check-circle-fill text-success me-1"></i> 1 = მოქმედება ერთ კასრზე</li>
                                <li class="text-muted"><i class="bi bi-check-circle-fill text-success me-1"></i> 2 = შიდა მარაგებიდან გადმოტანა</li>
                                <li class="text-muted"><i class="bi bi-check-circle-fill text-success me-1"></i> 3 = სხვა მეწარმის მარაგებიდან გადმოტანა</li>
                                <li class="text-muted"><i class="bi bi-check-circle-fill text-success me-1"></i> 4 = შიდა ჩამოხარისხება</li>
                            </ul>
                        </li>
                        <li class="list-group-item bg-light border-0 px-0 py-2">
                            <strong class="text-dark">საპირისპირო სახელი:</strong>
                            <span class="text-muted">საჭიროა თუ "ოპერაციის ტიპი" > 1 (მაგალითად, შიდა გადატანისას საპირისპირო ოპერაცია არის "(-) სხვა კასრში გადატანა")</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}