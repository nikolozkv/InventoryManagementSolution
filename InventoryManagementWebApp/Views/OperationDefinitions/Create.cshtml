@model InventoryManagementWebApp.Models.OperationDefinition // Assuming OperationDefinition is in this namespace

@{
    ViewData["Title"] = Model.OperationDefID == 0 ? "ოპერაციის დამატება" : "ოპერაციის რედაქტირება";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9 col-sm-12">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-primary text-white p-3 rounded-top-3 d-flex align-items-center justify-content-center">
                    <h2 class="card-title mb-0 fs-3">
                        <span class="fw-bold">@ViewData["Title"]</span>
                    </h2>
                </div>
                <div class="card-body p-4">
                    <form asp-action="@(Model.OperationDefID == 0 ? "Create" : "Edit")" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                        <input type="hidden" asp-for="OperationDefID" /> @* Hidden field for Edit action *@

                        <div class="row g-3">
                            <div class="col-12 mb-3">
                                <label asp-for="Name" class="form-label fw-semibold">
                                    <i class="bi bi-tag-fill me-1"></i> სახელი:
                                </label>
                                <input asp-for="Name" class="form-control" placeholder="ოპერაციის სახელი" aria-describedby="nameHelp" />
                                <div id="nameHelp" class="form-text text-muted">ოპერაციის სრული დასახელება.</div>
                                <span asp-validation-for="Name" class="text-danger fs-6 mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6 col-sm-12 mb-3">
                                <label asp-for="Math" class="form-label fw-semibold">
                                    <i class="bi bi-calculator-fill me-1"></i> არითმეტიკა:
                                </label>
                                <select asp-for="Math" class="form-select" asp-items="ViewBag.MathOptions">
                                    <option value="">-- აირჩიეთ არითმეტიკა --</option>
                                </select>
                                <span asp-validation-for="Math" class="text-danger fs-6 mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6 col-sm-12 mb-3">
                                <label asp-for="OperType" class="form-label fw-semibold">
                                    <i class="bi bi-gear-fill me-1"></i> ოპერაციის ტიპი:
                                </label>
                                <select asp-for="OperType" class="form-select" asp-items="ViewBag.OperTypeOptions">
                                    <option value="">-- აირჩიეთ ტიპი --</option>
                                </select>
                                <span asp-validation-for="OperType" class="text-danger fs-6 mt-1 d-block"></span>
                            </div>

                            <div class="col-12 mb-3">
                                <label asp-for="NameOpposite" class="form-label fw-semibold">
                                    <i class="bi bi-arrow-left-right me-1"></i> საპირისპირო სახელი:
                                </label>
                                <input asp-for="NameOpposite" class="form-control" placeholder="საპირისპირო ოპერაციის სახელი" aria-describedby="nameOppositeHelp" />
                                <div id="nameOppositeHelp" class="form-text text-muted">საჭიროა თუ ოპერაციის ტიპი > 1 (შიდა ან სხვა მეწარმის კასრიდან გადატანა).</div>
                                <span asp-validation-for="NameOpposite" class="text-danger fs-6 mt-1 d-block"></span>
                            </div>

                            <div class="col-12 mb-4">
                                <div class="form-check form-switch">
                                    @* Using form-switch for a nicer toggle *@
                                    <input class="form-check-input" type="checkbox" role="switch" id="PreserveBarrelState" asp-for="PreserveBarrelState">
                                    <label class="form-check-label fw-semibold" for="PreserveBarrelState">
                                        <i class="bi bi-stack-fill me-1"></i> შენარჩუნდეს კასრის მდგომარეობა
                                    </label>
                                    <div id="preserveBarrelHelp" class="form-text text-muted">მონიშნეთ თუ ამ ოპერაციამ არ უნდა შეცვალოს კასრის მდგომარეობა (მაგ. დოკუმენტაცია).</div>
                                </div>
                                <span asp-validation-for="PreserveBarrelState" class="text-danger fs-6 mt-1 d-block"></span>
                            </div>

                            <div class="col-12 text-center pt-3 border-top">
                                <div class="d-flex justify-content-center flex-wrap gap-3">
                                    <button type="submit" class="btn btn-success btn-lg me-3 px-4">
                                        <i class="bi bi-save-fill me-2"></i> 💾 შენახვა
                                    </button>
                                    <a asp-action="Index" class="btn btn-secondary btn-lg px-4">
                                        <i class="bi bi-arrow-left-circle-fill me-2"></i> 🔙 დაბრუნება
                                    </a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-light p-4 rounded-bottom-3">
                    <h5 class="fw-bold mb-3 text-primary">
                        <i class="bi bi-info-circle-fill me-2"></i> 🧾 სახელმძღვანელო
                    </h5>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item bg-light border-0 px-0 py-2">
                            <strong class="text-dark">არითმეტიკა:</strong>
                            <span class="text-muted"><code>+</code> = გაზრდა, <code>-</code> = შემცირება</span>
                        </li>
                        <li class="list-group-item bg-light border-0 px-0 py-2">
                            <strong class="text-dark">ოპერაციის ტიპი:</strong>
                            <ul class="list-unstyled ms-3 mt-2">
                                <li class="text-muted"><i class="bi bi-check-circle-fill text-success me-1"></i> 1 = მოქმედება ერთ კასრზე</li>
                                <li class="text-muted"><i class="bi bi-check-circle-fill text-success me-1"></i> 2 = შიდა გადატანა</li>
                                <li class="text-muted"><i class="bi bi-check-circle-fill text-success me-1"></i> 3 = სხვა მეწარმის კასრიდან გადატანა</li>
                                <li class="text-muted"><i class="bi bi-check-circle-fill text-success me-1"></i> 4 = შიდა ჩამოხარისხება</li>
                            </ul>
                        </li>
                        <li class="list-group-item bg-light border-0 px-0 py-2">
                            <strong class="text-dark">საპირისპირო სახელი:</strong>
                            <span class="text-muted">საჭიროა თუ "ოპერაციის ტიპი" > 1 (მაგალითად, შიდა გადატანისას საპირისპირო ოპერაცია არის "სხვა კასრში")</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}