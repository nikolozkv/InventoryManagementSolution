@model IEnumerable<InventoryManagementWebApp.Models.BeverageViewModel>

@{
    ViewData["Title"] = "🍷 სასმელის სახეობები";
}

<h1 class="main-title">@ViewData["Title"]</h1>

<form method="get" action="@Url.Action("Index", "Beverages")" class="search-form-container">
    <input type="text" name="search"
           placeholder="ძებნა (სახელი, ტიპი, კატეგორია, ფერი, შაქრიანობა...)"
           class="form-control"
           value="@ViewContext.HttpContext.Request.Query["search"]" />
    <button type="submit" class="btn btn-primary">🔍 ძებნა</button>
    <a href="@Url.Action("Index", "Beverages")" class="btn btn-outline-secondary">🔄 გასუფთავება</a>

    <a asp-action="Create" class="btn btn-success">➕ ახალი სასმელი</a>

    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">🔙 უკან</a>
</form>

<div class="table-responsive" style="max-height: 580px; overflow-y: auto;">
    <table class="table table-striped">
        <thead class="table-light" style="position: sticky; top: 0; z-index: 1;">
            <tr>
                <th>სახელი</th>
                <th>პროდუქტი</th>
                <th>კატეგორია</th>
                <th>ქვეკატეგორია</th>
                <th>ფერი</th>
                <th>შაქრიანობა</th>
                <th>სტატუსი</th>
                <th class="text-center">ქმედება</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var beverage in Model)
            {
                <tr>
                    <td>@beverage.Name</td>
                    <td>@beverage.ProductType</td>
                    <td>@beverage.Category</td>
                    <td>@beverage.SubCategory</td>
                    <td>@beverage.Color</td>
                    <td>@beverage.Sweetness</td>
                    <td>
                        @if (beverage.IsActive)
                        {
                            <span class="badge bg-success">აქტიური</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">არქივირებული</span>
                        }
                    </td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@beverage.BeverageID" class="btn btn-outline-primary btn-sm" title="რედაქტირება">✏️</a>
                        @if (beverage.IsActive)
                        {
                            <a asp-action="Delete" asp-route-id="@beverage.BeverageID" class="btn btn-outline-danger btn-sm" title="არქივირება">❌</a>
                        }
                        else
                        {
                            <a asp-action="Reactivate" asp-route-id="@beverage.BeverageID" class="btn btn-outline-success btn-sm" title="რეაქტივაცია">♻️</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    @* SweetAlert ბიბლიოთეკა *@
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // ✅ Html.Raw() ასწორებს სიმბოლოების პრობლემას (Encoding)
            var successMessage = '@Html.Raw(TempData["SuccessMessage"])';
            var errorMessage = '@Html.Raw(TempData["ErrorMessage"])';

            // ❌ თუ შეცდომაა
            if (errorMessage) {
                Swal.fire({
                    icon: 'error',
                    title: 'შეცდომა',
                    text: errorMessage,
                    confirmButtonText: 'დახურვა',
                    confirmButtonColor: '#d33'
                });
            }

            // ✅ თუ წარმატებაა (ტაიმერის გარეშე, ღილაკით "კარგი")
            if (successMessage) {
                Swal.fire({
                    icon: 'success',
                    title: 'წარმატება',
                    text: successMessage,
                    confirmButtonText: 'კარგი',
                    confirmButtonColor: '#198754'
                });
            }
        });
    </script>
}