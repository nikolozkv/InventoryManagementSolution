@model InventoryManagementWebApp.Models.BeverageCreateViewModel

@{
    ViewData["Title"] = "➕ ახალი სასმელის დამატება";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9 col-sm-12">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-primary text-white p-3 rounded-top-3 d-flex align-items-center justify-content-center">
                    <h2 class="card-title mb-0 fs-3">
                        <span class="fw-bold">@ViewData["Title"]</span>
                    </h2>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>
                        }

                        <div class="row g-3">
                            <div class="col-12 mb-3">
                                <label asp-for="Name" class="form-label fw-semibold">
                                    <i class="bi bi-tag-fill me-1"></i> სახელი:
                                </label>
                                <input asp-for="Name" class="form-control" placeholder="სასმელის სახელი" aria-describedby="nameHelp" />
                                <div id="nameHelp" class="form-text text-muted">სასმელის სრული დასახელება, რომელიც გამოჩნდება ინვენტარში.</div>
                                <span asp-validation-for="Name" class="text-danger fs-6 mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6 col-sm-12 mb-3">
                                <label asp-for="ProductTypeID" class="form-label fw-semibold">სასმელის ტიპი:</label>
                                <select asp-for="ProductTypeID" class="form-select" id="ProductTypeSelect">
                                    <option value="">-- აირჩიეთ ტიპი --</option>
                                    @foreach (var pt in (IEnumerable<InventoryManagementWebApp.Models.BeverageProductType>)ViewBag.ProductTypes)
                                    {
                                        <option value="@pt.ProductTypeID" data-bit="@pt.BitValue">@pt.Name</option>
                                    }
                                </select>
                                <span asp-validation-for="ProductTypeID" class="text-danger small mt-1"></span>
                            </div>

                            <div class="col-md-6 col-sm-12 mb-3">
                                <label asp-for="CategoryID" class="form-label fw-semibold">კატეგორია:</label>
                                <select asp-for="CategoryID" class="form-select" id="CategorySelect" disabled>
                                    <option value="">-- აირჩიეთ კატეგორია --</option>
                                    @foreach (var cat in (IEnumerable<InventoryManagementWebApp.Models.BeverageCategory>)ViewBag.Categories)
                                    {
                                        <option value="@cat.CategoryID" data-mask="@cat.TypeCodeMask">@cat.Name</option>
                                    }
                                </select>
                                <span asp-validation-for="CategoryID" class="text-danger small mt-1"></span>
                            </div>

                            <div class="col-md-6 col-sm-12 mb-3">
                                <label asp-for="SubCategoryID" class="form-label fw-semibold">ქვეკატეგორია:</label>
                                <select asp-for="SubCategoryID" class="form-select" id="SubCategorySelect" disabled>
                                    <option value="">-- აირჩიეთ ქვეკატეგორია --</option>
                                    @foreach (var sub in (IEnumerable<InventoryManagementWebApp.Models.BeverageSubCategory>)ViewBag.SubCategories)
                                    {
                                        <option value="@sub.SubCategoryID" data-mask="@sub.TypeCodeMask">@sub.Name</option>
                                    }
                                </select>
                                <span asp-validation-for="SubCategoryID" class="text-danger small mt-1"></span>
                            </div>

                            <div class="col-md-6 col-sm-12 mb-3">
                                <label asp-for="ColorID" class="form-label fw-semibold">ფერი:</label>
                                <select asp-for="ColorID" class="form-select" id="ColorSelect" disabled>
                                    <option value="">-- აირჩიეთ ფერი --</option>
                                    @foreach (var c in (IEnumerable<InventoryManagementWebApp.Models.BeverageColor>)ViewBag.Colors)
                                    {
                                        <option value="@c.ColorID" data-mask="@c.TypeCodeMask">@c.Name</option>
                                    }
                                </select>
                                <span asp-validation-for="ColorID" class="text-danger small mt-1"></span>
                            </div>

                            <div class="col-12 mb-3">
                                <label asp-for="SweetnessID" class="form-label fw-semibold">შაქრიანობა:</label>
                                <select asp-for="SweetnessID" class="form-select" id="SweetnessSelect" disabled>
                                    <option value="">-- აირჩიეთ შაქრიანობა --</option>
                                    @foreach (var sw in (IEnumerable<InventoryManagementWebApp.Models.BeverageSweetnessLevel>)ViewBag.SweetnessLevels)
                                    {
                                        <option value="@sw.SweetnessID" data-mask="@sw.TypeCodeMask">@sw.Name</option>
                                    }
                                </select>
                                <span asp-validation-for="SweetnessID" class="text-danger small mt-1"></span>
                            </div>

                            <div class="col-12 text-center pt-3 border-top mt-2">
                                <div class="d-flex justify-content-center flex-wrap gap-3">
                                    <button type="submit" class="btn btn-success btn-lg me-3 px-4">
                                        <i class="bi bi-save-fill me-2"></i> 💾 დამატება
                                    </button>
                                    <a asp-action="Index" class="btn btn-secondary btn-lg px-4">
                                        <i class="bi bi-arrow-left-circle-fill me-2"></i> 🔙 დაბრუნება
                                    </a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const typeSelect = document.getElementById("ProductTypeSelect");
            const dependentSelects = [
                document.getElementById("CategorySelect"),
                document.getElementById("SubCategorySelect"),
                document.getElementById("ColorSelect"),
                document.getElementById("SweetnessSelect")
            ];

            typeSelect.addEventListener("change", function () {
                const selectedOption = typeSelect.options[typeSelect.selectedIndex];
                const bit = parseInt(selectedOption.getAttribute("data-bit")) || 0;

                dependentSelects.forEach(select => {
                    if (bit === 0) {
                        select.disabled = true;
                        select.value = "";
                        return;
                    }
                    
                    select.disabled = false;
                    let hasValidOptions = false;

                    Array.from(select.options).forEach(option => {
                        if (option.value === "") return;

                        const mask = parseInt(option.getAttribute("data-mask")) || 0;

                        if ((mask & bit) > 0) {
                            option.hidden = false;
                            option.disabled = false;
                            hasValidOptions = true;
                        } else {
                            option.hidden = true;
                            option.disabled = true;
                        }
                    });

                    select.value = "";
                });
            });

            // Trigger on load if validation failed and a type was already selected
            if (typeSelect.value !== "") {
                typeSelect.dispatchEvent(new Event("change"));
            }
        });
    </script>
}