@model InventoryManagementWebApp.Models.Beverage

@{
    ViewData["Title"] = "წაშლა/არქივირება";
}

<div class="container py-5">
    @* Increased vertical padding for more breathing room *@
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10 col-sm-12">
            @* Adjusted column width for better readability of details *@
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-danger text-white p-3 rounded-top-3 d-flex align-items-center justify-content-center">
                    @* Changed header color to danger for delete context *@
                    <h2 class="card-title mb-0 fs-3">
                        <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i> @* Used a warning icon for attention *@
                        <span class="fw-bold">🚨 ყურადღება: წაშლა/არქივირება</span> @* Clearer, more urgent title *@
                    </h2>
                </div>
                <div class="card-body p-4">
                    <p class="lead text-center mb-4">
                        @* Styled warning message *@
                        თქვენ აპირებთ სასმელის შესახებ ინფორმაციის
                        <span class="fw-bold text-danger">წაშლას</span> ან <span class="fw-bold text-warning">არქივირებას</span>.
                        გთხოვთ, გადაამოწმოთ დეტალები:
                    </p>

                    <dl class="row mb-5 gx-3 gy-2">
                        @* Added gutter spacing for better alignment, increased bottom margin *@
                        <dt class="col-sm-4 text-sm-end fw-semibold">
                            @* Aligned labels to the right on small screens and up, made bold *@
                            <i class="bi bi-tag-fill me-1"></i> სახელი:
                        </dt>
                        <dd class="col-sm-8 text-dark">@Html.DisplayFor(model => model.Name)</dd>

                        <dt class="col-sm-4 text-sm-end fw-semibold">
                            <i class="bi bi-info-circle-fill me-1"></i> სტატუსი:
                        </dt>
                        <dd class="col-sm-8">
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success fs-6"><i class="bi bi-check-circle-fill me-1"></i> აქტიური</span> @* Larger font size for badge, added icon *@
                            }
                            else
                            {
                                <span class="badge bg-secondary fs-6"><i class="bi bi-archive-fill me-1"></i> არქივირებული</span> @* Larger font size for badge, added icon *@
                            }
                        </dd>

                        <dt class="col-sm-4 text-sm-end fw-semibold">
                            <i class="bi bi-bookmark-fill me-1"></i> პროდუქტის ტიპი:
                        </dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.ProductType.Name)</dd>

                        <dt class="col-sm-4 text-sm-end fw-semibold">
                            <i class="bi bi-collection-fill me-1"></i> კატეგორია:
                        </dt>
                        <dd class="col-sm-8" >@Html.DisplayFor(model => model.Category.Name)</dd>

                        <dt class="col-sm-4 text-sm-end fw-semibold">
                            <i class="bi bi-box-seam-fill me-1"></i> ქვეკატეგორია:
                        </dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.SubCategory.Name)</dd>

                        <dt class="col-sm-4 text-sm-end fw-semibold">
                            <i class="bi bi-palette-fill me-1"></i> ფერი:
                        </dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.Color.Name)</dd>

                        <dt class="col-sm-4 text-sm-end fw-semibold">
                            <i class="bi bi-sweet-fill me-1"></i> შაქრიანობა:
                        </dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.Sweetness.Name)</dd>
                    </dl>

                    <div class="text-center pt-3 border-top">
                        @if (Model.IsActive)
                        {
                            <!-- აქტიური სასმელის შემთხვევაში: არქივირების და წაშლის ღილაკები -->
                            <div class="d-flex justify-content-center flex-wrap gap-3">.
                                <!-- Delete button triggers a modal -->
                                <button type="button" class="btn btn-danger btn-lg px-4" data-bs-toggle="modal" data-bs-target="#deleteConfirmationModal" title="წაშლა">
                                    <i class="bi bi-trash-fill me-2"></i> 🗑️ წაშლა
                                </button>

                                <a asp-controller="Beverages" asp-action="Archive" asp-route-id="@Model.BeverageID" class="btn btn-warning btn-lg px-4" title="არქივირება">
                                    <i class="bi bi-archive-fill me-2"></i> 🗄️ არქივირება
                                </a>                                

                                <a asp-action="Index" class="btn btn-secondary btn-lg px-4" title="დაბრუნება">
                                    <i class="bi bi-arrow-left-circle-fill me-2"></i> 🔙 უკან
                                </a>
                            </div>
                        }
                        else
                        {
                            <!-- არქივირებული სასმელის შემთხვევაში: რეაქტივაციის ღილაკი -->
                            <div class="d-flex justify-content-center flex-wrap gap-3">
                                <a asp-controller="Beverages" asp-action="Reactivate" asp-route-id="@Model.BeverageID" class="btn btn-success btn-lg px-4" title="რეაქტივაცია">
                                    <i class="bi bi-arrow-clockwise me-2"></i> ♻️ რეაქტივაცია
                                </a>
                                <a asp-action="Index" class="btn btn-secondary btn-lg px-4" title="დაბრუნება">
                                    <i class="bi bi-arrow-left-circle-fill me-2"></i> 🔙 უკან
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal (outside the main container but still within the body) -->
<div class="modal fade" id="deleteConfirmationModal" tabindex="-1" aria-labelledby="deleteConfirmationModalLabel" aria-hidden="true" data-bs-backdrop="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteConfirmationModalLabel"><i class="bi bi-exclamation-octagon-fill me-2"></i> წაშლის დადასტურება</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>ნამდვილად გსურთ სასმელის <span class="fw-bold text-danger">"@Model.Name"</span> სამუდამოდ წაშლა?</p>
                <p class="text-danger small"><i class="bi bi-info-circle-fill me-1"></i> ამ მოქმედების გაუქმება შეუძლებელი იქნება!</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">გაუქმება</button>
                <form asp-controller="Beverages" asp-action="Delete" method="post" class="d-inline">
                    <input type="hidden" asp-for="BeverageID" />
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash-fill me-2"></i> წაშლა</button>
                </form>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}