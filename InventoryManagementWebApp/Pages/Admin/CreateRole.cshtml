@page "/Admin/CreateRole"
@model InventoryManagementWebApp.Pages.Admin.CreateRoleModel

@{
    ViewData["Title"] = "Create Role";
}

<style>
    .create-role-container {
        max-width: 600px;
        margin: 50px auto;
        padding: 30px;
        background-color: #ffffff;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .create-role-title {
        color: #2c3e50;
        font-size: 2rem;
        margin-bottom: 20px;
        font-weight: 700;
        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.05);
        text-align: center;
    }

    .btn {
        font-size: 0.9rem;
        padding: 0.4em 0.8em;
    }
</style>

<div class="create-role-container">
    <h1 class="create-role-title">Create Role</h1>

    <form method="post">
        <div class="form-group mb-3">
            <label asp-for="RoleName" class="form-label"></label>
            <input asp-for="RoleName" class="form-control" placeholder="Enter role name" />
            <span asp-validation-for="RoleName" class="text-danger"></span>
        </div>
        <div class="form-group mb-3">
            <label class="form-label">Accessible Pages</label>
            @foreach (var accessiblePage in Model.AccessiblePages)
            {
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" asp-for="SelectedPages" value="@accessiblePage" id="@accessiblePage" />
                    <label class="form-check-label" for="@accessiblePage">@accessiblePage</label>
                </div>
            }
            <span asp-validation-for="SelectedPages" class="text-danger"></span>
        </div>
        <div class="d-flex justify-content-between">
            <button type="submit" class="btn btn-primary">Create</button>
            <a href="/Admin/Roles" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
